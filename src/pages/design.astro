---
import Layout from '@layouts/Layout.astro';
import LinkPanel from '@components/LinkPanel.astro';

// Unlinked reference page documenting the site's current visual language.
// Every colour chip is painted by the real utility/token (a Tailwind class or a
// CSS variable) and its hex is read back from the rendered result at load — so a
// label can never silently drift from the source. The component demos are real
// instances. Not in the nav; reachable only by direct URL.

type Swatch = {
  name: string;   // token / class name shown as the label
  cls: string;    // the REAL Tailwind utility that paints the chip
  usage: string;  // where it's used on the site
};

const brand: Swatch[] = [
  { name: 'mdgc-blue', cls: 'bg-mdgc-blue', usage: 'Primary brand blue — icons, links, accents' },
  { name: 'mdgc-blue-light', cls: 'bg-mdgc-blue-light', usage: 'Light blue — nav links & accents on dark chrome' },
  { name: 'mdgc-blue-dark', cls: 'bg-mdgc-blue-dark', usage: 'Deep blue — gradients, hover states' },
];

const surfaces: Swatch[] = [
  { name: 'mdgc-mist', cls: 'bg-mdgc-mist', usage: 'Page background — pale blue tint behind content' },
  { name: 'white', cls: 'bg-white', usage: 'Card & panel surfaces' },
  { name: 'gray-900', cls: 'bg-gray-900', usage: 'Dark chrome — header, hero & footer' },
];

const text: Swatch[] = [
  { name: '--color-text-heading', cls: 'bg-[var(--color-text-heading)]', usage: 'Headings (gray-900)' },
  { name: '--color-text-body', cls: 'bg-[var(--color-text-body)]', usage: 'Body copy (slate-600)' },
];

const accents: Swatch[] = [
  { name: 'orange-500', cls: 'bg-orange-500', usage: '.metrix-button — Metrix result links' },
  { name: 'amber-500', cls: 'bg-amber-500', usage: '.callout — left border' },
  { name: 'amber-50', cls: 'bg-amber-50', usage: '.callout — background' },
];
---

<Layout title="Design language" subtitle="A living reference for the site's visual system">
  <div class="dl">
    <p class="dl-lead">
      This page documents the <strong>existing</strong> visual language of the MDGC site. It is
      unlinked from navigation — reachable only by direct URL — as a reference for anyone editing the
      design. Every swatch is painted by the real Tailwind utility or CSS token, and its hex is read
      back from the rendered colour on load; the component demos are real instances. So the page
      can't silently drift from the site.
    </p>

    <!-- COLOUR -->
    <section class="dl-section">
      <h2>Colour</h2>
      <p>A single blue family carries the brand. Surfaces are near-white on a pale blue page tint.
         A small set of semantic accents (orange, amber) are used sparingly for specific roles.</p>

      <h3>Brand blues</h3>
      <div class="swatch-grid">
        {brand.map((s) => (
          <div class="swatch">
            <div class={`swatch-chip ${s.cls}`}></div>
            <code>{s.name}</code>
            <span>{s.usage}</span>
          </div>
        ))}
      </div>

      <h3>Surfaces & chrome</h3>
      <div class="swatch-grid">
        {surfaces.map((s) => (
          <div class="swatch">
            <div class={`swatch-chip ${s.cls}`}></div>
            <code>{s.name}</code>
            <span>{s.usage}</span>
          </div>
        ))}
      </div>

      <h3>Text</h3>
      <div class="swatch-grid">
        {text.map((s) => (
          <div class="swatch">
            <div class={`swatch-chip ${s.cls}`}></div>
            <code>{s.name}</code>
            <span>{s.usage}</span>
          </div>
        ))}
      </div>

      <h3>Semantic accents</h3>
      <div class="swatch-grid">
        {accents.map((s) => (
          <div class="swatch">
            <div class={`swatch-chip ${s.cls}`}></div>
            <code>{s.name}</code>
            <span>{s.usage}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- TYPOGRAPHY -->
    <section class="dl-section">
      <h2>Typography</h2>
      <p>Two typefaces, both loaded from Google Fonts via Astro's font provider.</p>

      <div class="type-specimen">
        <div class="type-meta">
          <code>font-display</code> · Nunito · weights 300/400/600/700
          <span>Currently used only for the header wordmark.</span>
        </div>
        <p class="font-display text-4xl font-bold" style="color: var(--color-text-heading)">Melbourne Disc Golf Club</p>
      </div>

      <div class="type-specimen">
        <div class="type-meta">
          <code>font-sans</code> (default) · Inter · weights 400/600/700/800/900
          <span>Used for all headings and body copy.</span>
        </div>
        <p class="text-4xl font-bold" style="color: var(--color-text-heading)">The quick brown disc flies far</p>
        <p class="text-base mt-2" style="color: var(--color-text-body)">
          The quick brown disc flies far over the fairway — 0123456789.
        </p>
      </div>

      <h3>Heading scale (as used)</h3>
      <div class="type-scale">
        <div><span class="tag">PageHero h1 · text-4xl font-bold</span><p class="text-4xl font-bold" style="color:var(--color-text-heading)">Page title</p></div>
        <div><span class="tag">Section h2 · text-2xl font-semibold</span><p class="text-2xl font-semibold" style="color:var(--color-text-heading)">Section heading</p></div>
        <div><span class="tag">prose h2</span><p class="text-xl font-bold" style="color:var(--color-text-heading)">Prose H2 (with top rule)</p></div>
        <div><span class="tag">prose h3</span><p class="text-lg font-bold" style="color:var(--color-text-body)">Prose H3</p></div>
        <div><span class="tag">body · text-base</span><p class="text-base" style="color:var(--color-text-body)">Body copy sits at slate-600 for a softer read; headings darken to gray-900.</p></div>
      </div>
    </section>

    <!-- CHROME -->
    <section class="dl-section">
      <h2>Chrome & gradients</h2>
      <p>Dark, blue-tinted gradients frame the page top and bottom; the content sits on the light mist tint between them.</p>

      <div class="chrome-samples">
        <div>
          <span class="tag">Header · from-gray-900 to-mdgc-blue-dark</span>
          <div class="chrome-bar bg-linear-to-r from-gray-900 to-mdgc-blue-dark"></div>
        </div>
        <div>
          <span class="tag">PageHero · from-gray-900 to-mdgc-blue-dark</span>
          <div class="chrome-bar bg-linear-to-r from-gray-900 to-mdgc-blue-dark"></div>
        </div>
        <div>
          <span class="tag">Hero divider · from-mdgc-blue-light to-gray-900</span>
          <div class="chrome-bar bg-linear-to-r from-mdgc-blue-light to-gray-900" style="height:0.5rem"></div>
        </div>
        <div>
          <span class="tag">Footer · gray-900</span>
          <div class="chrome-bar bg-gray-900"></div>
        </div>
      </div>
    </section>

    <!-- COMPONENTS -->
    <section class="dl-section">
      <h2>Components</h2>

      <h3>Link panel (card)</h3>
      <p>The dominant content motif: a white card with an icon, title and description. Lifts and
         deepens its shadow on hover.</p>
      <div class="grid gap-6 sm:grid-cols-2 not-prose my-6">
        <LinkPanel href="/disc-golf" title="Disc Golf" description="about the game" icon="heroicons:academic-cap" />
        <LinkPanel href="https://example.com" title="External link" description="opens in a new tab" icon="heroicons:shopping-bag" />
      </div>

      <h3>Callout</h3>
      <div class="callout"><p>Amber-bordered callout for asides and notes — <code>.callout</code>.</p></div>

      <h3>Metrix button</h3>
      <p>Inline orange chip linking to Metrix results: <span class="metrix-button">Results ↗</span> (<code>.metrix-button</code>).</p>
    </section>

    <!-- MOTION -->
    <section class="dl-section">
      <h2>Motion</h2>
      <p>Motion is restrained and interaction-driven — there is no page-load choreography.</p>
      <ul class="dl-list">
        <li><strong>Links</strong> scale to <code>1.05</code> on hover (block links only; inline prose links thicken their underline instead).</li>
        <li><strong>Logo</strong> scales to <code>1.15</code> on hover.</li>
        <li><strong>Cards</strong> lift <code>1px</code> and deepen their shadow on hover.</li>
        <li><strong>Header</strong> hides on scroll-down and returns on scroll-up.</li>
      </ul>
      <p>Hover the demo links to feel the timing:
        <a href="#" onclick="return false" class="text-mdgc-blue">a block link zoom</a>.</p>
    </section>

    <!-- LAYOUT -->
    <section class="dl-section">
      <h2>Layout & spacing</h2>
      <ul class="dl-list">
        <li><code>.content-width</code> — <code>max-w-7xl</code>, centred, responsive horizontal padding. The page container.</li>
        <li><code>.text-width</code> / <code>.prose</code> — <code>max-w-4xl</code>, centred. Reading-width text columns.</li>
        <li><code>&lt;Section&gt;</code> — vertical rhythm block (<code>my-12</code>) with optional heading.</li>
        <li><code>&lt;Grid&gt;</code> — auto-fit responsive card grid (default min column <code>250px</code>).</li>
      </ul>
    </section>
  </div>
</Layout>

<style>
  .dl {
    max-width: 72rem;
    margin: 2rem auto 4rem;
  }

  .dl-lead {
    color: var(--color-text-body);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 48rem;
    margin-bottom: 2.5rem;
  }

  .dl-section {
    padding: 2rem 0;
    border-top: 1px solid #dbe4ee;
  }

  .dl-section > h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0 0 0.5rem;
  }

  .dl-section > h3 {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-mdgc-blue-dark);
    margin: 2rem 0 0.75rem;
  }

  .dl-section p {
    color: var(--color-text-body);
    max-width: 48rem;
    margin: 0.5rem 0;
    line-height: 1.6;
  }

  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin: 1rem 0 0.5rem;
  }

  .swatch {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .swatch-chip {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    height: 4.5rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 0.75rem;
    font-weight: 600;
    color: #1e293b; /* slate-800 — overridden per-chip by the contrast script */
    box-shadow: 0 4px 12px rgba(6, 61, 99, 0.08);
  }

  .swatch-chip.on-dark {
    color: rgba(255, 255, 255, 0.9);
  }

  .swatch code {
    font-size: 0.8rem;
    color: var(--color-text-heading);
  }

  .swatch span {
    font-size: 0.8rem;
    color: var(--color-text-body);
    line-height: 1.4;
  }

  .type-specimen,
  .type-scale > div {
    border: 1px solid #dbe4ee;
    border-radius: 0.75rem;
    background: #fff;
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
  }

  .type-meta,
  .tag {
    display: block;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--color-mdgc-blue-dark);
    margin-bottom: 0.5rem;
  }

  .type-meta span {
    display: block;
    color: var(--color-text-body);
    font-family: var(--font-sans);
    margin-top: 0.15rem;
  }

  .type-scale {
    margin-top: 1rem;
  }

  .chrome-samples {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .chrome-bar {
    height: 3rem;
    border-radius: 0.5rem;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.06);
  }

  .dl-list {
    color: var(--color-text-body);
    line-height: 1.7;
    padding-left: 1.25rem;
    list-style: disc;
    max-width: 48rem;
  }

  .dl-list li {
    margin: 0.35rem 0;
  }

  .dl code {
    background: #eef4fa;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
  }
</style>

<script>
  // Label each swatch with the hex it actually renders as, and pick a legible text
  // colour from the chip's own luminance. The colour is never hard-coded here — it's
  // read back from the compiled Tailwind utility / CSS token, so labels can't drift.
  // Rasterising through a 1px canvas normalises any CSS colour (Tailwind v4 palette
  // values serialise as oklch) down to real sRGB bytes.
  const ctx = document.createElement('canvas').getContext('2d')!;

  function resolveRgb(color: string): number[] {
    ctx.fillStyle = '#000';
    ctx.fillStyle = color;
    ctx.fillRect(0, 0, 1, 1);
    const [r, g, b] = ctx.getImageData(0, 0, 1, 1).data;
    return [r, g, b];
  }

  function toHex([r, g, b]: number[]): string {
    return '#' + [r, g, b].map((x) => x.toString(16).padStart(2, '0')).join('').toUpperCase();
  }

  function isDark([r, g, b]: number[]): boolean {
    const lin = [r, g, b].map((v) => {
      const c = v / 255;
      return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    });
    const L = 0.2126 * lin[0] + 0.7152 * lin[1] + 0.0722 * lin[2];
    return L < 0.5;
  }

  document.querySelectorAll<HTMLElement>('.swatch-chip').forEach((chip) => {
    const rgb = resolveRgb(getComputedStyle(chip).backgroundColor);
    chip.textContent = toHex(rgb);
    chip.classList.toggle('on-dark', isDark(rgb));
  });
</script>
