---
import Layout from '@layouts/Layout.astro';
import LinkPanel from '@components/LinkPanel.astro';

// Unlinked reference page documenting the site's current visual language, organised
// around the site's anatomy: shared Foundations (colour + type), then the Header,
// Footer and Prose content. Colour chips are painted by the real utility/token and
// their hex is read back from the rendered result on load, and the header/footer
// close-ups are built from the same utility classes the real components use — so the
// page can't silently drift. Not in the nav; reachable only by direct URL.

type Swatch = {
  name: string;   // token / class name shown as the label
  cls: string;    // the REAL Tailwind utility that paints the chip
  usage: string;  // where it's used on the site
};

const brand: Swatch[] = [
  { name: 'mdgc-blue', cls: 'bg-mdgc-blue', usage: 'Primary brand blue — icons, links, accents' },
  { name: 'mdgc-blue-light', cls: 'bg-mdgc-blue-light', usage: 'Light blue — nav links & accents on dark chrome' },
  { name: 'mdgc-blue-dark', cls: 'bg-mdgc-blue-dark', usage: 'Deep blue — gradients, hover states' },
];

const surfaces: Swatch[] = [
  { name: 'mdgc-mist', cls: 'bg-mdgc-mist', usage: 'Page background — pale blue tint behind content' },
  { name: 'white', cls: 'bg-white', usage: 'Card & panel surfaces' },
  { name: 'gray-900', cls: 'bg-gray-900', usage: 'Dark chrome — header, hero & footer' },
];

const text: Swatch[] = [
  { name: '--color-text-heading', cls: 'bg-[var(--color-text-heading)]', usage: 'Headings (gray-900)' },
  { name: '--color-text-body', cls: 'bg-[var(--color-text-body)]', usage: 'Body copy (slate-600)' },
];

const accents: Swatch[] = [
  { name: 'orange-500', cls: 'bg-orange-500', usage: '.metrix-button — Metrix result links' },
  { name: 'amber-500', cls: 'bg-amber-500', usage: '.social-callout — left border' },
  { name: 'amber-50', cls: 'bg-amber-50', usage: '.social-callout — background' },
];
---

<Layout title="Design language" subtitle="A living reference for the site's visual system">
  <div class="dl">
    <p class="dl-lead">
      This page documents the <strong>existing</strong> visual language of the MDGC site, organised
      around its anatomy: shared <a href="#foundations">foundations</a>, then the
      <a href="#header">header</a>, <a href="#footer">footer</a> and <a href="#prose">prose content</a>.
      It is unlinked from navigation — reachable only by direct URL. Colour chips are painted by the
      real token and their hex read back from the rendered result on load; the chrome close-ups use
      the same utility classes as the real components. So the page can't silently drift from the site.
    </p>

    <!-- FOUNDATIONS -->
    <section class="dl-section" id="foundations">
      <h2>Foundations</h2>

      <h3>Colour</h3>
      <p>A single blue family carries the brand, on near-white surfaces over a pale blue page tint.
         A few semantic accents (orange, amber) are used sparingly for specific roles.</p>

      <div class="swatch-block"><span class="mini-label">Brand blues</span>
        <div class="swatch-grid">
          {brand.map((s) => (
            <div class="swatch"><div class={`swatch-chip ${s.cls}`}></div><code>{s.name}</code><span>{s.usage}</span></div>
          ))}
        </div>
      </div>

      <div class="swatch-block"><span class="mini-label">Surfaces</span>
        <div class="swatch-grid">
          {surfaces.map((s) => (
            <div class="swatch"><div class={`swatch-chip ${s.cls}`}></div><code>{s.name}</code><span>{s.usage}</span></div>
          ))}
        </div>
      </div>

      <div class="swatch-block"><span class="mini-label">Text</span>
        <div class="swatch-grid">
          {text.map((s) => (
            <div class="swatch"><div class={`swatch-chip ${s.cls}`}></div><code>{s.name}</code><span>{s.usage}</span></div>
          ))}
        </div>
      </div>

      <div class="swatch-block"><span class="mini-label">Semantic accents</span>
        <div class="swatch-grid">
          {accents.map((s) => (
            <div class="swatch"><div class={`swatch-chip ${s.cls}`}></div><code>{s.name}</code><span>{s.usage}</span></div>
          ))}
        </div>
      </div>

      <h3>Typography</h3>
      <p>Two typefaces, both loaded from Google Fonts via Astro's font provider.</p>

      <div class="type-specimen">
        <div class="type-meta"><code>font-display</code> · Nunito · 300/400/600/700
          <span>Used only for the header wordmark.</span></div>
        <p class="font-display text-3xl font-bold" style="color: var(--color-text-heading)">Melbourne Disc Golf Club</p>
      </div>

      <div class="type-specimen">
        <div class="type-meta"><code>font-sans</code> (default) · Inter · 400/600/700/800/900
          <span>Everything else — headings and body.</span></div>
        <p class="text-3xl font-bold" style="color: var(--color-text-heading)">The quick brown disc flies far</p>
        <p class="text-base mt-1" style="color: var(--color-text-body)">The quick brown disc flies far over the fairway — 0123456789.</p>
      </div>
    </section>

    <!-- HEADER -->
    <section class="dl-section" id="header">
      <h2>Header</h2>
      <p>The header (visible at the top of this page) has two parts: a sticky <strong>navigation
         strip</strong> and the <strong>page hero</strong> that carries the title. Both sit on the
         <code>from-gray-900 → mdgc-blue-dark</code> gradient with white text.</p>

      <h3>Navigation strip</h3>
      <p>The wordmark uses <code>font-display</code> (Nunito); links are pill-shaped, resting at
         <code>mdgc-blue-light</code> and turning white when active or hovered.</p>
      <div class="dark-stage bg-linear-to-r from-gray-900 to-mdgc-blue-dark text-white">
        <div class="stage-row">
          <span class="font-display text-base">Melbourne Disc Golf Club</span>
          <span class="text-mdgc-blue-light text-sm px-4 py-2 rounded-lg border border-mdgc-blue-light/25">Disc Golf</span>
          <span class="text-white text-sm px-4 py-2 rounded-lg border border-mdgc-blue-light/25 bg-mdgc-blue-dark">Club (active)</span>
        </div>
      </div>

      <p>Items with sub-pages open a dropdown (hover the real nav above to see it). The panel and its
         items reuse these classes:</p>
      <div class="dark-stage bg-linear-to-r from-gray-900 to-mdgc-blue-dark">
        <div class="w-max rounded-b-lg rounded-tr-lg border border-mdgc-blue-light/25 bg-gray-900 p-1.5">
          <span class="block rounded-md px-5 py-1 text-sm text-mdgc-blue-light">News</span>
          <span class="block rounded-md px-5 py-1 text-sm text-white bg-white/15">Membership (active)</span>
          <span class="block rounded-md px-5 py-1 text-sm text-mdgc-blue-light">Board</span>
        </div>
      </div>
      <p class="anno">Behaviour: the strip is <strong>sticky</strong> with a “headroom” effect — it
         slides up out of view on scroll-down and returns on scroll-up.</p>

      <h3>Page hero</h3>
      <p>The title is an <code>h1</code> at <code>text-4xl font-bold</code>; an optional subtitle sits
         below at <code>text-xl</code>, and a nav-derived back-link above at
         <code>text-sm mdgc-blue-light</code>.</p>
      <div class="dark-stage bg-linear-to-r from-gray-900 to-mdgc-blue-dark text-white">
        <span class="text-sm text-mdgc-blue-light">← Club</span>
        <p class="text-4xl font-bold mt-1">Page title</p>
        <p class="text-xl mt-2">An optional subtitle line</p>
      </div>
      <span class="mini-label">Hero divider · from-mdgc-blue-light to-gray-900</span>
      <div class="chrome-bar bg-linear-to-r from-mdgc-blue-light to-gray-900" style="height:0.25rem"></div>
    </section>

    <!-- FOOTER -->
    <section class="dl-section" id="footer">
      <h2>Footer</h2>
      <p>The footer (at the bottom of this page) is a solid <code>gray-900</code> block: the logo, a
         row of navigation columns (section title + sub-links), and a bottom bar with the copyright,
         last-updated stamp and the CMS / GitHub / report-issue icons.</p>
      <div class="dark-stage bg-gray-900 text-white">
        <div class="stage-cols">
          <div>
            <h4 class="text-mdgc-blue-light font-semibold m-0">Club</h4>
            <ul class="space-y-0.5 list-none p-0 m-0 mt-1">
              <li><span class="text-sm text-mdgc-blue-light">News</span></li>
              <li><span class="text-sm text-mdgc-blue-light">Membership</span></li>
              <li><span class="text-sm text-mdgc-blue-light">Board</span></li>
            </ul>
          </div>
          <div>
            <h4 class="text-mdgc-blue-light font-semibold m-0">Courses</h4>
            <ul class="space-y-0.5 list-none p-0 m-0 mt-1">
              <li><span class="text-sm text-mdgc-blue-light">Bald Hill</span></li>
              <li><span class="text-sm text-mdgc-blue-light">Ruffey Lake</span></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-4 pt-2 text-gray-400 text-sm">© Melbourne Disc Golf Club. All rights reserved.</div>
      </div>
      <p class="anno">Tokens: <code>bg-gray-900</code> surface, <code>mdgc-blue-light</code> links
         (white on hover), <code>gray-700</code> divider, <code>gray-400</code> muted text.</p>
    </section>

    <!-- PROSE -->
    <section class="dl-section" id="prose">
      <h2>Prose content</h2>
      <p>Page bodies render as <code>.prose</code> — a centred <code>max-w-4xl</code> reading column in
         body colour (<code>slate-600</code>). The Tailwind Typography plugin provides the base, with
         local overrides in <code>global.css</code>. A live example:</p>

      <div class="prose-demo">
        <div class="prose">
          <p>An intro paragraph with an <a href="#prose">inline link</a> that darkens and thickens its
             underline on hover (block links elsewhere scale slightly instead). Headings sit at
             <strong>gray-900</strong>, body text at slate-600.</p>
          <h2>A prose heading</h2>
          <p>The <code>h2</code> above carries a top rule and generous top margin to separate sections.</p>
          <h3>A sub-heading</h3>
          <ul>
            <li>Unordered list item</li>
            <li>Another item</li>
          </ul>
          <ol>
            <li>Ordered list item</li>
            <li>Another step</li>
          </ol>
          <table>
            <thead><tr><th>Course</th><th>Suburb</th></tr></thead>
            <tbody>
              <tr><td>Bald Hill</td><td>Clarinda</td></tr>
              <tr><td>Ruffey Lake</td><td>Templestowe</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <h3>Heading styles</h3>
      <ul class="dl-list">
        <li><strong>Hero h1</strong> — <code>text-4xl font-bold</code>, white on the header gradient (see above).</li>
        <li><strong>Section h2</strong> — <code>text-2xl font-semibold</code>, from the <code>&lt;Section&gt;</code> component.</li>
        <li><strong>prose h2</strong> — top rule (<code>1px</code> border) + generous top margin; darkens to gray-900.</li>
        <li><strong>prose h3 / h4</strong> — smaller, tighter spacing; h3 in body colour.</li>
      </ul>

      <h3>Content blocks</h3>
      <p>Reusable blocks that appear within page bodies:</p>

      <p class="mini-label">Link panel — the dominant card motif (lifts &amp; deepens its shadow on hover)</p>
      <div class="grid gap-6 sm:grid-cols-2 not-prose my-4">
        <LinkPanel href="/disc-golf" title="Disc Golf" description="about the game" icon="heroicons:academic-cap" />
        <LinkPanel href="https://example.com" title="External link" description="opens in a new tab" icon="heroicons:shopping-bag" />
      </div>

      <p class="mini-label"><code>.social-callout</code> — amber note box, used on social-day pages</p>
      <div class="social-callout"><p>Pre-registration is required for all Social Days.</p></div>

      <p class="mini-label"><code>.metrix-button</code> — inline chip linking to Metrix results</p>
      <p><span class="metrix-button">Results ↗</span></p>

      <h3>Widths</h3>
      <ul class="dl-list">
        <li><code>.content-width</code> — <code>max-w-7xl</code>, centred, responsive padding. The page container.</li>
        <li><code>.text-width</code> / <code>.prose</code> — <code>max-w-4xl</code>, centred. Reading-width columns.</li>
      </ul>
    </section>
  </div>
</Layout>

<style>
  .dl {
    max-width: 72rem;
    margin: 2rem auto 4rem;
  }

  .dl-lead {
    color: var(--color-text-body);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 52rem;
    margin-bottom: 2.5rem;
  }

  .dl-lead a { color: var(--color-mdgc-blue-dark); text-decoration: underline; }

  .dl-section {
    padding: 2rem 0;
    border-top: 1px solid #dbe4ee;
    scroll-margin-top: 6rem;
  }

  .dl-section > h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0 0 0.5rem;
  }

  .dl-section > h3 {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-mdgc-blue-dark);
    margin: 2rem 0 0.75rem;
  }

  .dl-section > p {
    color: var(--color-text-body);
    max-width: 52rem;
    margin: 0.5rem 0;
    line-height: 1.6;
  }

  .anno {
    font-size: 0.9rem;
  }

  .mini-label {
    display: block;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--color-mdgc-blue-dark);
    margin: 1rem 0 0.4rem;
  }

  .swatch-block { margin-bottom: 1rem; }

  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .swatch {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .swatch-chip {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    height: 4rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 0.75rem;
    font-weight: 600;
    color: #1e293b; /* slate-800 — overridden per-chip by the contrast script */
    box-shadow: 0 4px 12px rgba(6, 61, 99, 0.08);
  }

  .swatch-chip.on-dark { color: rgba(255, 255, 255, 0.9); }

  .swatch code { font-size: 0.8rem; color: var(--color-text-heading); }
  .swatch span { font-size: 0.8rem; color: var(--color-text-body); line-height: 1.4; }

  .type-specimen {
    border: 1px solid #dbe4ee;
    border-radius: 0.75rem;
    background: #fff;
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
  }

  .type-meta {
    display: block;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--color-mdgc-blue-dark);
    margin-bottom: 0.5rem;
  }

  .type-meta span {
    display: block;
    color: var(--color-text-body);
    font-family: var(--font-sans);
    margin-top: 0.15rem;
  }

  /* Dark backdrop for showing light-on-dark chrome elements in context. */
  .dark-stage {
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    margin: 0.5rem 0 1rem;
  }

  .stage-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .stage-cols {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
  }

  .chrome-bar {
    height: 3rem;
    border-radius: 0.5rem;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.06);
  }

  /* Let the real .prose styling show, but drop its max-width centring inside the demo. */
  .prose-demo {
    border: 1px solid #dbe4ee;
    border-radius: 0.75rem;
    background: #fff;
    padding: 0.5rem 1.5rem 1.5rem;
    margin: 1rem 0;
  }

  .prose-demo .prose { max-width: none; margin: 0; }
  .prose-demo .prose > :first-child { margin-top: 0; }

  .dl-list {
    color: var(--color-text-body);
    line-height: 1.7;
    padding-left: 1.25rem;
    list-style: disc;
    max-width: 52rem;
  }

  .dl-list li { margin: 0.35rem 0; }

  .dl code {
    background: #eef4fa;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
  }
</style>

<script>
  // Label each swatch with the hex it actually renders as, and pick a legible text
  // colour from the chip's own luminance. The colour is never hard-coded here — it's
  // read back from the compiled Tailwind utility / CSS token, so labels can't drift.
  // Rasterising through a 1px canvas normalises any CSS colour (Tailwind v4 palette
  // values serialise as oklch) down to real sRGB bytes.
  const ctx = document.createElement('canvas').getContext('2d')!;

  function resolveRgb(color: string): number[] {
    ctx.fillStyle = '#000';
    ctx.fillStyle = color;
    ctx.fillRect(0, 0, 1, 1);
    const [r, g, b] = ctx.getImageData(0, 0, 1, 1).data;
    return [r, g, b];
  }

  function toHex([r, g, b]: number[]): string {
    return '#' + [r, g, b].map((x) => x.toString(16).padStart(2, '0')).join('').toUpperCase();
  }

  function isDark([r, g, b]: number[]): boolean {
    const lin = [r, g, b].map((v) => {
      const c = v / 255;
      return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    });
    const L = 0.2126 * lin[0] + 0.7152 * lin[1] + 0.0722 * lin[2];
    return L < 0.5;
  }

  document.querySelectorAll<HTMLElement>('.swatch-chip').forEach((chip) => {
    const rgb = resolveRgb(getComputedStyle(chip).backgroundColor);
    chip.textContent = toHex(rgb);
    chip.classList.toggle('on-dark', isDark(rgb));
  });
</script>
