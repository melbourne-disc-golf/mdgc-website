---
import { getEntry, render } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import Text from '@components/Text.astro';
import Grid from '@components/Grid.astro';
import LinkPanel from '@components/LinkPanel.astro';
import CourseCard from '@components/CourseCard.astro';
import { formatDateRange } from '@utils/dates';
import { getPublishedEvents, dateToPlainDate } from '@utils/events';

export async function getStaticPaths() {
  const events = await getPublishedEvents();
  return events.flatMap((event) => [
    {
      params: { slug: event.id },
      props: { event, redirect: undefined as string | undefined },
    },
    ...(event.data.aliases ?? []).map((alias) => ({
      params: { slug: alias },
      props: { event: undefined as typeof event | undefined, redirect: `/events/${event.id}` },
    })),
  ]);
}

const { event: eventProp, redirect } = Astro.props;
if (redirect) return Astro.redirect(redirect, 301);

const event = eventProp!;
const { Content } = await render(event);
const eventStartDate = dateToPlainDate(event.data.date);
const eventEndDate = event.data.endDate ? dateToPlainDate(event.data.endDate) : eventStartDate;

// Resolve the referenced courses, so we can show a card for each
const courses = [];
if (event.data.courses) {
  for (const courseRef of event.data.courses) {
    const course = await getEntry(courseRef);
    if (course) courses.push(course);
  }
}
---

<Layout
  title={event.data.title}
  subtitle={formatDateRange(dateToPlainDate(event.data.date), event.data.endDate ? dateToPlainDate(event.data.endDate) : undefined)}
  cmsPath={`/collections/events/entries/${event.id}`}
  heroImage={event.data.heroImage && {
    src: event.data.heroImage,
    alt: event.data.title,
  }}
>
  <Text>

    <Content />

    {event.data.registrationUrl && (
      <section class="hide-after-date" data-hide-after={eventStartDate}>
        <h2>Registration</h2>
        <Grid>
          <LinkPanel
            href={event.data.registrationUrl}
            title="Register here"
            icon="mdi:calendar-check"
          />
        </Grid>
      </section>
    )}

    {courses.length > 0 && (
      <section>
        <h2>{courses.length > 1 ? 'Courses' : 'Course'}</h2>
        <Grid>
          {courses.map((course) => (
            <CourseCard
              name={course.data.title}
              href={`/courses/${course.id}`}
              location={course.data.suburb}
              image={course.data.thumbnail || course.data.mainImage}
            />
          ))}
        </Grid>
      </section>
    )}

    {event.data.pdgaEventId && (
      <section>
        <h2>PDGA event info</h2>
        <Grid>
          <LinkPanel
            href={`https://www.pdga.com/tour/event/${event.data.pdgaEventId}`}
            title="Official event page"
            icon="heroicons:information-circle"
          />
          <div
            class="show-during-event"
            data-show-from={eventStartDate.add({ days: -3 })}
            data-show-until={eventEndDate.add({ days: 1 })}
            hidden
          >
            <LinkPanel
              href={`https://www.pdga.com/live/event/${event.data.pdgaEventId}/`}
              title="Live scoring"
              icon="heroicons:presentation-chart-line"
            />
          </div>
        </Grid>
      </section>
    )}

</Text>

</Layout>

<script>
  const today = new Date().toISOString().slice(0, 10);
  document.querySelectorAll('.hide-after-date').forEach((el) => {
    const hideAfter = el.getAttribute('data-hide-after');
    if (hideAfter && today > hideAfter) {
      el.remove();
    }
  });
  document.querySelectorAll('.show-during-event').forEach((el) => {
    const from = el.getAttribute('data-show-from');
    const until = el.getAttribute('data-show-until');
    if (from && until && today >= from && today <= until) {
      el.removeAttribute('hidden');
    }
  });
</script>
