---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';

export async function getStaticPaths() {
  const seasons = await getCollection('metrixStandings');
  return seasons.map((season) => ({
    params: { season: String(season.data.id) },
    props: { season },
  }));
}

const { season } = Astro.props;
const { name, rounds, standings } = season.data;

// Map Metrix course ids to our course pages.
const courses = await getCollection('courses');
const courseByMetrixId = new Map<string, { slug: string; title: string }>();
for (const course of courses) {
  for (const metrixId of course.data.metrixCourseIds ?? []) {
    courseByMetrixId.set(metrixId, { slug: course.id, title: course.data.title });
  }
}

const hasStandings = standings.some((p) => p.total > 0);

function formatDate(d: string): string {
  return new Date(d).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }).replace(' ', '-');
}
---

<Layout title={name} subtitle="Social day results and season standings">
  <div class="my-8 space-y-12">

    <section>
      <h2 class="text-2xl font-bold text-mdgc-blue-dark mb-4">Rounds</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        {rounds.map((r) => {
          const course = courseByMetrixId.get(r.courseId)?.title ?? r.courseName.split('&rarr;')[0].trim();
          const label = `R${r.round}: ${formatDate(r.date)} @ ${course}`;
          return (
            <li>
              {r.played ? (
                <a
                  href={`/events/social/results/${season.data.id}/${r.id}`}
                  class="block rounded-lg border border-mdgc-blue bg-mdgc-blue/5 px-3 py-2 text-sm font-medium text-mdgc-blue-dark hover:bg-mdgc-blue hover:text-white transition"
                >{label}</a>
              ) : (
                <span
                  class="block rounded-lg border border-dashed border-gray-200 px-3 py-2 text-sm text-gray-400"
                  title="Not yet played"
                >{label}</span>
              )}
            </li>
          );
        })}
      </ul>
    </section>

    {hasStandings && (
      <section>
        <h2 class="text-2xl font-bold text-mdgc-blue-dark mb-4">Season standings</h2>
        <p class="text-sm text-gray-600 mb-3">Metrix tour points across all rounds. Higher is better.</p>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm border-collapse">
            <thead>
              <tr class="bg-mdgc-blue-dark text-white">
                <th class="px-2 py-2 text-right">#</th>
                <th class="px-3 py-2 text-left sticky left-0 bg-mdgc-blue-dark">Player</th>
                {rounds.map((r) => (
                  <th class="px-2 py-2 text-right" title={r.name}>R{r.round}</th>
                ))}
                <th class="px-3 py-2 text-right">Total</th>
              </tr>
            </thead>
            <tbody>
              {standings.map((p, i) => (
                <tr class={i % 2 ? 'bg-gray-50' : 'bg-white'}>
                  <td class="px-2 py-1.5 text-right text-gray-500">{p.place}</td>
                  <td class={`px-3 py-1.5 font-medium whitespace-nowrap sticky left-0 ${i % 2 ? 'bg-gray-50' : 'bg-white'}`}>{p.name}</td>
                  {p.eventResults.map((pts) => (
                    <td class="px-2 py-1.5 text-right text-gray-600">{pts ?? '·'}</td>
                  ))}
                  <td class="px-3 py-1.5 text-right font-semibold">{p.total}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

  </div>
</Layout>
