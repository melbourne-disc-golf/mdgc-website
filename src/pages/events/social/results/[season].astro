---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { Temporal } from '@js-temporal/polyfill';
import { formatDateRange } from '@utils/dates';
import { getSeasons } from '@utils/metrix';

export async function getStaticPaths() {
  return getSeasons().map((season) => ({
    params: { season: String(season.id) },
    props: { season },
  }));
}

const { season } = Astro.props;
const { id: seasonId, name, dateStart, dateEnd, rounds } = season;
const playedRounds = rounds.filter((round) => round.played);
const nextRound = rounds.find((round) => !round.played);
const completion = rounds.length ? Math.round((playedRounds.length / rounds.length) * 100) : 0;

const subtitle = dateStart
  ? formatDateRange(
      Temporal.PlainDate.from(dateStart),
      dateEnd ? Temporal.PlainDate.from(dateEnd) : undefined
    )
  : undefined;

const courses = await getCollection('courses');
const courseByMetrixId = new Map<string, { slug: string; title: string }>();
for (const course of courses) {
  for (const metrixId of course.data.metrixCourseIds ?? []) {
    courseByMetrixId.set(metrixId, { slug: course.id, title: course.data.title });
  }
}

function formatDate(d: string): string {
  return new Date(d).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
}

function courseFor(courseId: string, courseName: string): { title: string; href?: string } {
  const matched = courseByMetrixId.get(courseId);
  if (matched) return { title: matched.title, href: `/courses/${matched.slug}` };
  return { title: courseName.split('&rarr;')[0].trim() };
}
---

<Layout title={name} subtitle={subtitle} backLink={{ href: '/events/social/results', text: 'Results' }}>
  <div class="space-y-8">
    <section class="grid gap-4 lg:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.8fr)]">
      <div class="surface p-6 sm:p-7">
        <p class="eyebrow">Season overview</p>
        <h2 class="mt-3 font-display text-3xl font-black text-mdgc-ink sm:text-4xl">{playedRounds.length} rounds played</h2>
        <p class="mt-4 max-w-3xl text-slate-600">
          Open a played round to see division results, handicap scores and hole-by-hole scorecards.
          Upcoming rounds are shown here so the season still makes sense before every event has results.
        </p>
        <div class="mt-6 h-2 overflow-hidden rounded-full bg-slate-100">
          <div class="h-full rounded-full bg-mdgc-green" style={`width: ${completion}%`}></div>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
        <div class="metric-pill">
          <span class="block text-xs uppercase text-slate-500">Progress</span>
          <strong class="mt-1 block text-3xl text-mdgc-ink">{completion}%</strong>
        </div>
        <div class="metric-pill">
          <span class="block text-xs uppercase text-slate-500">Played</span>
          <strong class="mt-1 block text-3xl text-mdgc-ink">{playedRounds.length}</strong>
        </div>
        <div class="metric-pill">
          <span class="block text-xs uppercase text-slate-500">Next round</span>
          <strong class="mt-1 block text-3xl text-mdgc-ink">{nextRound ? nextRound.round : '-'}</strong>
        </div>
      </div>
    </section>

    <section>
      <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Rounds</p>
          <h2 class="font-display text-3xl font-black text-mdgc-ink">Season schedule</h2>
        </div>
        <p class="text-sm text-slate-500">{playedRounds.length} of {rounds.length} rounds have scorecards.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {rounds.map((round) => {
          const course = courseFor(round.courseId, round.courseName);
          const content = (
            <>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <span class={`inline-flex rounded-md px-2.5 py-1 text-xs font-bold uppercase ${round.played ? 'bg-mdgc-mint/35 text-mdgc-green' : 'bg-slate-100 text-slate-500'}`}>
                    {round.played ? 'Results ready' : 'Upcoming'}
                  </span>
                  <h3 class="mt-3 text-xl font-black text-mdgc-ink">Round {round.round}</h3>
                </div>
                <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-sm font-bold text-slate-700">{formatDate(round.date)}</span>
              </div>
              <p class="mt-4 text-base font-semibold text-slate-700">{round.name}</p>
              {course.href ? (
                <a href={course.href} class="mt-1 inline-flex text-sm font-semibold text-mdgc-green">{course.title}</a>
              ) : (
                <p class="mt-1 text-sm text-slate-500">{course.title}</p>
              )}
            </>
          );

          return round.played ? (
            <a href={`/events/social/results/${seasonId}/${round.id}`} class="surface group block p-5 hover:border-mdgc-green hover:shadow-lg">
              {content}
              <span class="mt-5 inline-flex text-sm font-bold text-mdgc-green group-hover:text-slate-950">Open scorecard</span>
            </a>
          ) : (
            <article class="surface border-dashed p-5 opacity-80">
              {content}
              <span class="mt-5 inline-flex text-sm font-bold text-slate-400">Awaiting results</span>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</Layout>
