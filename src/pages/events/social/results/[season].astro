---
import Layout from '@layouts/Layout.astro';
import SocialResultsBrowser from '@components/SocialResultsBrowser.astro';
import { getSeasons } from '@utils/metrix';
import { socialSeasonSlug } from '@utils/social-results';

export async function getStaticPaths() {
  return getSeasons().flatMap((season) => [
    {
      params: { season: socialSeasonSlug(season) },
      props: { season },
    },
    {
      params: { season: String(season.id) },
      props: { season },
    },
  ]);
}

const seasons = getSeasons();
const defaultSeason = seasons.find((season) => season.socialDays.some((day) => day.played)) ?? seasons[0];
const { season } = Astro.props;
---

<Layout title={season.name} subtitle="Round tabs, handicap leaders and division scorecards from Disc Golf Metrix." backLink={{ href: '/events/social', text: 'Social Days' }}>
  <SocialResultsBrowser season={season} seasons={seasons} defaultSeasonId={defaultSeason?.id ?? season.id} />
</Layout>
