---
import Layout from '@layouts/Layout.astro';
import Grid from '@components/Grid.astro';
import LinkPanel from '@components/LinkPanel.astro';
import { Temporal } from '@js-temporal/polyfill';
import { formatDateRange } from '@utils/dates';
import { getEvent, getPlayedEventRefs, getSeasons } from '@utils/metrix';

export async function getStaticPaths() {
  return getPlayedEventRefs().map(({ seasonId, eventId }) => ({
    params: { season: String(seasonId), event: String(eventId) },
    props: { event: getEvent(eventId)! },
  }));
}

const { event } = Astro.props;
const { name, date, par, tracks, divisions } = event;

const subtitle = formatDateRange(Temporal.PlainDate.from(date));

// Back-link up to this round's season.
const season = getSeasons().find((s) => s.id === event.seasonId);
const backLink = {
  href: `/events/social/results/${event.seasonId}`,
  text: season?.name ?? 'Season',
};

// Shade a hole score's background relative to its par (disc-golf scorecard colours).
function holeClass(score: number | null, holePar: number): string {
  if (score === null) return 'text-slate-300';
  if (score === 1) return 'bg-[#ffd60a] text-[#3f2600]';       // ace
  const diff = score - holePar;
  if (diff <= -2) return 'bg-[#55d57d] text-[#06351f]';        // eagle or better
  if (diff === -1) return 'bg-[#d8f0e5] text-[#0b3f38]';       // birdie
  if (diff === 0) return 'text-slate-700';                      // par
  if (diff === 1) return 'bg-[#ffe1c2] text-[#7a3b00]';        // bogey
  return 'bg-[#f8e7e4] text-[#8c2c27]';                        // double bogey or worse
}

function formatDiff(diff: number): string {
  return diff > 0 ? `+${diff}` : String(diff);
}

function fmt2(n: number | null): string {
  return n === null ? '–' : n.toFixed(2);
}

---

<Layout title={name} subtitle={subtitle} backLink={backLink}>
  <div class="my-8 space-y-10">

    {divisions.map((division) => {
      const nets = division.players.map((p) => p.net).filter((n): n is number => n !== null);
      const bestNet = nets.length ? Math.min(...nets) : null;
      return (
      <section>
        <h2 class="text-lg font-bold text-white px-4 py-2.5 rounded-t-lg bg-linear-to-r from-mdgc-blue-dark to-mdgc-blue">{division.name}</h2>
        <div class="overflow-x-auto border border-t-0 border-slate-200 rounded-b-lg">
          <table class="min-w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[#d7eaff] text-mdgc-blue-dark">
                <th class="px-3 py-2 text-left sticky left-0 bg-inherit">Player</th>
                <th class="px-2 py-2 text-right" title="Handicap score">HC</th>
                <th class="px-2 py-2 text-center">Pos</th>
                <th class="px-2 py-2 text-right" title="Raw score">Raw</th>
                <th class="px-2 py-2 text-right">+/-</th>
                {tracks.map((t) => (
                  <th class="px-1.5 py-2 text-right font-medium" title={`Par ${t.par}`}>{t.number}</th>
                ))}
                <th class="px-2 py-2 text-right" title="Metrix rating">Rating</th>
              </tr>
              <tr class="bg-[#eaf4ff] text-mdgc-blue-dark/70 text-xs">
                <th class="px-3 py-1 sticky left-0 bg-inherit"></th>
                <th></th>
                <th></th>
                <th class="px-2 py-1 text-right">{par}</th>
                <th class="px-2 py-1 text-right">Par</th>
                {tracks.map((t) => (
                  <th class="px-1.5 py-1 text-right font-normal">{t.par}</th>
                ))}
                <th></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {division.players.map((p) => (
                <tr class="odd:bg-white even:bg-slate-50/70 hover:bg-mdgc-blue-light/10">
                  <td class="px-3 py-1.5 font-medium whitespace-nowrap sticky left-0 bg-inherit">{p.name}</td>
                  <td class={`px-2 py-1.5 text-right ${p.net !== null && p.net === bestNet ? 'font-bold text-slate-800' : 'text-slate-600'}`}>{fmt2(p.net)}</td>
                  <td class="px-2 py-1.5 text-center">
                    {p.pos <= 3 ? (
                      <span class={`podium-badge podium-${p.pos}`}>{p.pos}</span>
                    ) : (
                      <span class="text-slate-500">{p.pos}</span>
                    )}
                  </td>
                  <td class="px-2 py-1.5 text-right text-slate-600">{p.sum}</td>
                  <td class="px-2 py-1.5 text-right text-slate-600">{formatDiff(p.diff)}</td>
                  {p.holes.map((score, h) => (
                    <td class={`px-1.5 py-1.5 text-right tabular-nums ${holeClass(score, tracks[h]?.par ?? par)}`}>{score ?? '–'}</td>
                  ))}
                  <td class="px-2 py-1.5 text-right text-slate-500">{p.rating ?? '–'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
      );
    })}

    <Grid>
      <LinkPanel
        image="https://discgolfmetrix.com/assets/img/favicon.png"
        href={`https://discgolfmetrix.com/${event.id}`}
        title="View on Metrix"
        description="this round on Disc Golf Metrix"
      />
    </Grid>

  </div>
</Layout>

<style>
  /* Gold / silver / bronze position badges. */
  .podium-badge {
    display: inline-grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    color: #152018;
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.75), 0 2px 5px rgba(31, 54, 44, 0.18);
  }
  .podium-1 { background: linear-gradient(145deg, #fff4ba, #e2a51d); }
  .podium-2 { background: linear-gradient(145deg, #ffffff, #aeb9c2); }
  .podium-3 { background: linear-gradient(145deg, #ffd9aa, #b36b27); color: #271606; }
</style>
