---
import Layout from '@layouts/Layout.astro';
import { Temporal } from '@js-temporal/polyfill';
import { formatDateRange } from '@utils/dates';
import { getSeasons, type Season } from '@utils/metrix';

const today = Temporal.Now.plainDateISO().toString();
const seasons = getSeasons(); // newest first

// Bucket seasons relative to today. `seasons` is newest-first, so `previous`
// comes out in reverse-chronological order, as we want.
const current: Season[] = [];
const upcoming: Season[] = [];
const previous: Season[] = [];
for (const season of seasons) {
  if (season.dateStart && season.dateStart > today) upcoming.push(season);
  else if (season.dateEnd && season.dateEnd < today) previous.push(season);
  else current.push(season);
}

const sections = [
  { title: 'Current season', seasons: current },
  { title: 'Next season', seasons: upcoming },
  { title: 'Previous seasons', seasons: previous },
].filter((s) => s.seasons.length > 0);

function seasonRange(season: Season): string | undefined {
  if (!season.dateStart) return undefined;
  return formatDateRange(
    Temporal.PlainDate.from(season.dateStart),
    season.dateEnd ? Temporal.PlainDate.from(season.dateEnd) : undefined
  );
}
---

<Layout title="Social days by season" subtitle="upcoming rounds and past results, season by season">
  <div class="my-8 space-y-12">
    <p class="text-slate-600">
      Information is sourced from <a class="text-mdgc-blue underline" href="https://discgolfmetrix.com/" target="_blank" rel="noopener noreferrer">Disc Golf Metrix</a> and updated automatically.
    </p>

    {sections.map((section) => (
      <section class="space-y-3">
        <h2 class="section-heading">{section.title}</h2>
        <ul class="space-y-2">
          {section.seasons.map((season) => {
            const playedDays = season.socialDays.filter((d) => d.played).length;
            return (
              <li>
                <a
                  href={`/events/social/seasons/${season.id}`}
                  class="block rounded-lg border border-slate-200 px-4 py-3 hover:border-mdgc-blue hover:bg-mdgc-blue/5 transition"
                >
                  <div class="flex items-baseline justify-between gap-4">
                    <span class="font-semibold text-mdgc-blue-dark">{season.name}</span>
                    <span class="text-sm text-slate-500 whitespace-nowrap">{seasonRange(season)}</span>
                  </div>
                  <p class="mt-0.5 text-sm text-slate-600">{playedDays} of {season.socialDays.length} social days played</p>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</Layout>
