---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface HeroImage {
	src: ImageMetadata;
	alt: string;
	caption?: string;
}

export interface BackLink {
	href: string;
	text: string;
}

export interface Props {
	title: string;
	subtitle?: string;
	heroImage?: HeroImage;
	backLink?: BackLink;
}

const { title, subtitle, heroImage, backLink } = Astro.props;
---

<div class="bg-linear-to-r from-slate-700 to-mdgc-blue-dark text-white">
	<div class={`content-width px-6 pb-6 flex flex-col gap-6 lg:flex-row lg:items-center lg:gap-10 ${backLink ? 'pt-3' : 'pt-6'}`}>
		<div id="title-content" class="flex-1 min-w-0 lg:flex lg:flex-col lg:justify-center">
			<div id="title-and-subtitle">
				{backLink && (
					<a href={backLink.href} class="no-print inline-block text-sm text-mdgc-blue-light hover:text-white hover:underline mb-3">← {backLink.text}</a>
				)}
				<h1 class="text-4xl font-bold">{title}</h1>
				{subtitle && <p class="text-xl mt-2">{subtitle}</p>}
			</div>
		</div>
		{heroImage && (
			<figure class="m-0 flex flex-col lg:w-2/3">
				<Image
					src={heroImage.src}
					alt={heroImage.alt}
					class="block mx-auto max-h-96 w-auto max-w-full rounded-lg"
				/>
				{heroImage.caption && (
					<figcaption class="text-xs text-slate-200/70 mt-2 italic text-center">
						{heroImage.caption}
					</figcaption>
				)}
			</figure>
		)}
	</div>
</div>
<div class="h-1 bg-linear-to-r from-mdgc-blue-light to-slate-900"></div>
