---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	imageClass?: string;
	figureClass?: string;
}

const { src, alt, caption, imageClass = "", figureClass = "" } = Astro.props;
---

<figure class={`max-w-65 mx-auto md:mx-0 mt-4 md:mt-0 mb-4 md:float-right md:ml-6 ${figureClass}`}>
	<Image
		src={src}
		alt={alt}
		title={alt}
		class={`w-full rounded-lg object-cover ${imageClass}`}
		inferSize={true}
	/>
	{caption && (
		<figcaption class="text-sm text-slate-600 mt-2 text-center italic">
			{caption}
		</figcaption>
	)}
</figure>
