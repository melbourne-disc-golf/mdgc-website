      </div>
    </div>
    <div class="stats-card-grid">
      ${statsCard('Imported Rounds', stats.importedEvents.length, `${stats.events.length} ${stats.seasonLabel} rounds scheduled`)}
      ${statsCard('Player Rounds', totalRounds.toLocaleString('en-AU'), `${formatDecimal(avgField, 1)} average field`)}
      ${statsCard('Unique Players', totalPlayers.toLocaleString('en-AU'), `${stats.playerProfilesFivePlus} with 5+ rounds`)}
      ${statsCard('Holes Scored', totalHoles.toLocaleString('en-AU'), `${percent(stats.totalSummary.birdieBetter, totalHoles)} birdie or better`)}
    </div>
  </section>

  <section class="stats-panel scoring-panel">
    <div class="section-head compact-section-head">
      <div>
        <h2>Scoring Mix</h2>
        <p>Every imported hole score, grouped by Metrix score colour.</p>
      </div>
    </div>
    ${scoreMixBlock(stats.totalCounts)}
  </section>

  <section class="stats-layout">
    <article class="stats-panel">
      <div class="section-head compact-section-head">
        <div>
          <h2>Attendance</h2>
          <p>Largest field: ${esc(topAttendance ? `${topAttendance.players} at ${roundVenueLabel(topAttendance.event)}` : 'No rounds yet')}.</p>
        </div>
      </div>
      ${attendanceChart(stats.eventStats)}
    </article>

    <article class="stats-panel">
      <div class="section-head compact-section-head">
        <div>
          <h2>Best To-Par Rounds</h2>
          <p>Lowest score to par, then raw score as the tiebreaker.</p>
        </div>
      </div>
      ${statsTable([
        { label: 'Player', className: 'player-col', value: (row) => row.player },
        { label: 'Event', className: 'event-col', value: (row) => row.event },
        { label: '+/-', className: 'number-col', sortType: 'number', value: (row) => row.toPar, sortValue: (row) => row.toParValue },
        { label: 'Raw', className: 'number-col', sortType: 'number', value: (row) => row.raw ?? '', sortValue: (row) => row.raw },
        { label: 'Div', className: 'tiny-col', value: (row) => row.division || '' },
      ], topRoundRows(stats.bestToPar), 'No score rows imported yet.', { className: 'top-rounds-table compact-stats-table' })}
    </article>
  </section>

  <section class="stats-layout">
    <article class="stats-panel">
      <div class="section-head compact-section-head">
        <div>
          <h2>Prize Count Board</h2>
          <p>Checklist-imported prize winners only. CTB and handicap prizes are counted separately.</p>
        </div>
      </div>
      ${statsTable([
        { label: 'Player', className: 'player-col', value: (row: PrizeProfile) => row.name },
        { label: 'Total', shortLabel: 'Tot', className: 'number-col', sortType: 'number', value: (row: PrizeProfile) => row.total, sortValue: (row: PrizeProfile) => row.total },
        { label: 'CTB', className: 'number-col', sortType: 'number', value: (row: PrizeProfile) => row.ctb, sortValue: (row: PrizeProfile) => row.ctb },
        { label: 'HC', className: 'number-col', sortType: 'number', value: (row: PrizeProfile) => row.handicap, sortValue: (row: PrizeProfile) => row.handicap },
      ], stats.prizeBoard, 'No prize rows imported yet.', { className: 'prize-count-table compact-stats-table' })}
    </article>

    <article class="stats-panel">
      <div class="section-head compact-section-head">
        <div>
          <h2>Round Difficulty</h2>
          <p>Based on average score to par across each field.</p>
        </div>
      </div>
      <div class="difficulty-pair">
        ${statsCard('Lowest Field Average', easiestEvent ? roundVenueLabel(easiestEvent.event) : '-', easiestEvent ? `${formatSigned(easiestEvent.avgToPar)} average` : '')}
        ${statsCard('Highest Field Average', toughestEvent ? roundVenueLabel(toughestEvent.event) : '-', toughestEvent ? `${formatSigned(toughestEvent.avgToPar)} average` : '')}
      </div>
      ${statsTable([
        { label: 'Round', shortLabel: 'Rd', value: (row: EventStats) => roundLabel(row.event) },
        { label: 'Venue', value: (row: EventStats) => row.event.venue || '' },
        { label: 'Avg +/-', shortLabel: '+/-', className: 'number-col', sortType: 'number', value: (row: EventStats) => formatSigned(row.avgToPar), sortValue: (row: EventStats) => row.avgToPar, cellClass: (row: EventStats) => difficultyHeatClass(row.avgToPar) },
        { label: 'Players', shortLabel: 'Plyrs', className: 'number-col', sortType: 'number', value: (row: EventStats) => row.players, sortValue: (row: EventStats) => row.players },
        { label: 'Birdie+', shortLabel: 'Bird+', className: 'number-col', sortType: 'number', value: (row: EventStats) => percent(row.summary.birdieBetter, row.summary.total), sortValue: (row: EventStats) => percentValue(row.summary.birdieBetter, row.summary.total), cellClass: (row: EventStats) => heatClass('good', percentValue(row.summary.birdieBetter, row.summary.total), [8, 16, 24, 32]) },
      ], stats.eventStats, 'No round stats yet.', { className: 'difficulty-table compact-stats-table' })}
    </article>
  </section>

  <section class="stats-panel player-profile-panel">
    <div class="section-head compact-section-head profile-panel-head">
      <div>
        <h2>Player Scoring Profiles</h2>
        <p>Birdie+ includes aces, eagles, and birdies.</p>
      </div>
      ${profileFilterControl()}
    </div>
    ${statsTable([
      { label: 'Player', value: (row: PlayerProfile) => row.name },
      { label: 'Days', sortType: 'number', value: (row: PlayerProfile) => row.rounds, sortValue: (row: PlayerProfile) => row.rounds },
      { label: 'Birdie+', shortLabel: 'Bird+', sortType: 'number', value: (row: PlayerProfile) => percent(row.summary.birdieBetter, row.summary.total), sortValue: (row: PlayerProfile) => percentValue(row.summary.birdieBetter, row.summary.total), cellClass: (row: PlayerProfile) => heatClass('good', percentValue(row.summary.birdieBetter, row.summary.total), [8, 16, 24, 32]) },
      { label: 'Par', sortType: 'number', value: (row: PlayerProfile) => percent(row.counts.pars, row.summary.total), sortValue: (row: PlayerProfile) => percentValue(row.counts.pars, row.summary.total), cellClass: (row: PlayerProfile) => heatClass('neutral', percentValue(row.counts.pars, row.summary.total), [25, 35, 45, 55]) },
      { label: 'Bogey', sortType: 'number', value: (row: PlayerProfile) => percent(row.counts.bogeys, row.summary.total), sortValue: (row: PlayerProfile) => percentValue(row.counts.bogeys, row.summary.total), cellClass: (row: PlayerProfile) => heatClass('warn', percentValue(row.counts.bogeys, row.summary.total), [15, 25, 35, 45]) },
      { label: 'Double+', shortLabel: 'Dbl+', sortType: 'number', value: (row: PlayerProfile) => percent(row.counts.doublePlus, row.summary.total), sortValue: (row: PlayerProfile) => percentValue(row.counts.doublePlus, row.summary.total), cellClass: (row: PlayerProfile) => heatClass('bad', percentValue(row.counts.doublePlus, row.summary.total), [3, 7, 11, 15]) },
      { label: 'Avg +/-', shortLabel: 'Avg', sortType: 'number', value: (row: PlayerProfile) => formatSigned(row.avgToPar), sortValue: (row: PlayerProfile) => row.avgToPar, cellClass: (row: PlayerProfile) => difficultyHeatClass(row.avgToPar) },
      { label: 'Best +/-', shortLabel: 'Best', sortType: 'number', value: (row: PlayerProfile) => formatSigned(row.bestToPar), sortValue: (row: PlayerProfile) => row.bestToPar, cellClass: (row: PlayerProfile) => difficultyHeatClass(row.bestToPar) },
    ], stats.playerProfiles, 'No player profile rows yet.', { className: 'player-profile-table', rowAttributes: profileRowAttributes })}
  </section>
</div>`;
}

function seasonShortLabel(value: Season): string {
  if (value.name.includes('S2')) return 'S2';
  if (value.name.includes('S1')) return 'S1';
  if (/MDGC\s+2026\s+Social\s+Days$/i.test(value.name.trim())) return 'S1';
  const match = value.name.match(/Season\s+(\d+)/i);
  return match ? `S${match[1]}` : String(value.id);
}

function resultHref(value: Season): string {
  return value.id === defaultSeasonId ? baseHref : `${baseHref}/${value.id}`;
}

function statsHref(value: Season): string {
  return value.id === defaultSeasonId ? `${baseHref}/stats` : `${baseHref}/${value.id}/stats`;
}
