<script>
  document.querySelectorAll('[data-stats-page]').forEach((page) => {
    const controls = page.querySelector('[data-stats-controls]');
    if (!controls) return;
    const allInput = controls.querySelector('[data-stats-all]');
    const divisionInputs = Array.from(controls.querySelectorAll('[data-stats-division]'));
    const profileSelects = Array.from(page.querySelectorAll('[data-profile-min]'));
    let profileMinimum = 5;

    const selectedDivisions = () => {
      if (allInput && allInput.checked) return [];
      return divisionInputs
        .filter((input) => input.checked)
        .map((input) => input.value)
        .sort();
    };

    const applyProfileFilter = () => {
      page.querySelectorAll('[data-profile-row]').forEach((row) => {
        const rounds = Number(row.dataset.profileRounds || '0');
        row.hidden = rounds < profileMinimum;
      });
    };

    const applyStatsFilters = () => {
      const divisions = selectedDivisions();
      if (!divisions.length && allInput) {
        allInput.checked = true;
        divisionInputs.forEach((input) => {
          input.checked = false;
        });
      }
      const key = divisions.length ? divisions.join('-') : 'all';
      page.querySelectorAll('[data-stats-view]').forEach((view) => {
        view.hidden = view.dataset.statsView !== key;
      });
      applyProfileFilter();
    };

    if (allInput) {
      allInput.addEventListener('change', () => {
        if (allInput.checked) {
          divisionInputs.forEach((input) => {
            input.checked = false;
          });
        }
        applyStatsFilters();
      });
    }

    divisionInputs.forEach((input) => {
      input.addEventListener('change', () => {
        if (input.checked && allInput) allInput.checked = false;
        if (!divisionInputs.some((item) => item.checked) && allInput) allInput.checked = true;
        applyStatsFilters();
      });
    });

    profileSelects.forEach((select) => {
      select.addEventListener('change', () => {
        profileMinimum = Number(select.value) || 1;
        profileSelects.forEach((item) => {
          item.value = String(profileMinimum);
        });
        applyProfileFilter();
      });
    });

    applyStatsFilters();
  });

  document.querySelectorAll('[data-sortable-table]').forEach((table) => {
    const headers = Array.from(table.querySelectorAll('thead th'));
    const tbody = table.tBodies[0];
    if (!headers.length || !tbody) return;

    const valueFor = (row, index, type) => {
      const cell = row.cells[index];
      const raw = cell ? (cell.dataset.sortValue || cell.textContent || '').trim() : '';
      if (type === 'number') {
        const number = Number(raw.replace(/,/g, '').replace(/%/g, '').replace(/^\+/, ''));
        return Number.isFinite(number) ? number : null;
      }
      return raw.toLocaleLowerCase('en-AU');
    };

    headers.forEach((header, index) => {
      const button = header.querySelector('[data-sort-index]');
      if (!button) return;
      button.addEventListener('click', () => {
        const type = button.dataset.sortType || 'text';
        const current = header.getAttribute('aria-sort');
        const next = current ? (current === 'ascending' ? 'descending' : 'ascending') : (type === 'number' ? 'descending' : 'ascending');
        const direction = next === 'ascending' ? 1 : -1;
        const rows = Array.from(tbody.rows);

        headers.forEach((item) => item.removeAttribute('aria-sort'));
        header.setAttribute('aria-sort', next);

        rows.sort((rowA, rowB) => {
          const valueA = valueFor(rowA, index, type);
          const valueB = valueFor(rowB, index, type);
          const missingA = valueA === null || valueA === '';
          const missingB = valueB === null || valueB === '';
          if (missingA && missingB) return 0;
          if (missingA) return 1;
          if (missingB) return -1;
          if (type === 'number') return (valueA - valueB) * direction;
          return String(valueA).localeCompare(String(valueB), 'en-AU', { numeric: true }) * direction;
        });

        rows.forEach((row) => tbody.appendChild(row));
      });
    });
  });
</script>

