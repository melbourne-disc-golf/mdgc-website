---
import s1ResultsData from '@data/social-results/s1.json';
import s2ResultsData from '@data/social-results/s2.json';
import type { Season } from '@utils/metrix';

interface Props {
  season: Season;
  seasons: Season[];
  baseHref?: string;
  defaultSeasonId?: number;
}

interface ResultHole {
  hole?: string | number;
  score?: string | number | null;
  scoreClass?: string;
}

type ResultRow = Record<string, unknown> & {
  name?: string;
  division?: string;
  rating?: string | number;
  rawScore?: string | number;
  toPar?: string | number;
  holes?: ResultHole[];
};

interface PrizeRow {
  prize?: string;
  name?: string;
  detail?: string;
  division?: string;
  hole?: string | number;
  note?: string;
}

interface ResultEvent {
  round: string | number;
  label?: string;
  name?: string;
  date?: string;
  venue?: string;
  metrixId?: string | number;
  status?: string;
  prizeWinners?: PrizeRow[];
  prizeEmailRows?: PrizeRow[];
  prizes?: PrizeRow[];
  handicapLeaders?: PrizeRow[];
  divisions?: Record<string, ResultRow[]>;
}

interface ResultsData {
  season?: {
    label?: string;
    name?: string;
    metrixId?: string | number;
    metrixUrl?: string;
  };
  events?: ResultEvent[];
}

interface ResultEntry {
  event: ResultEvent;
  division: string;
  row: ResultRow;
}

interface ScoreCounts {
  aces: number;
  eagles: number;
  birdies: number;
  pars: number;
  bogeys: number;
  doublePlus: number;
}

interface ScoreSummary {
  total: number;
  birdieBetter: number;
  birdieBetterPct: number;
  parPct: number;
  bogeyPct: number;
  doublePlusPct: number;
}

interface PlayerProfile {
  name: string;
  rounds: number;
  holes: number;
  counts: ScoreCounts;
  toPars: number[];
  rawScores: number[];
  summary: ScoreSummary;
  avgToPar: number | null;
  bestToPar: number;
}

interface EventStats {
  event: ResultEvent;
  players: number;
  counts: ScoreCounts;
  summary: ScoreSummary;
  avgRaw: number | null;
  avgToPar: number | null;
}

interface PrizeProfile {
  name: string;
  total: number;
  ctb: number;
  handicap: number;
}

interface StatsVariant {
  key: string;
  label: string;
  divisions: string[] | null;
}

interface SeasonStats {
  events: ResultEvent[];
  seasonLabel: string;
  importedEvents: ResultEvent[];
  rows: ResultEntry[];
  players: Map<string, PlayerProfile>;
  totalCounts: ScoreCounts;
  totalSummary: ScoreSummary;
  eventStats: EventStats[];
  bestToPar: ResultEntry[];
  playerProfiles: PlayerProfile[];
  playerProfilesFivePlus: number;
  playerProfilesThreePlus: number;
  prizeBoard: PrizeProfile[];
}

interface TableHeader<T> {
  label: string;
  shortLabel?: string;
  className?: string;
  sortType?: 'text' | 'number';
  value: (row: T) => string | number | null | undefined;
  sortValue?: (row: T) => string | number | null | undefined;
  cellClass?: string | ((row: T) => string);
}

const { season, seasons, baseHref = '/events/social/results', defaultSeasonId = season.id } = Astro.props;
const RESULT_DIVISIONS = ['A', 'B', 'C', 'D', 'X/Z'];
const STATS_FILTER_DIVISIONS = ['A', 'B', 'C', 'D'];
const publicResultsData = [s1ResultsData, s2ResultsData] as ResultsData[];
const publicSeason =
  publicResultsData.find((data) => String(data.season?.metrixId ?? '') === String(season.id)) ??
  publicResultsData.find((data) => data.season?.name?.includes('S1')) ??
  publicResultsData[0];
const events = resultEvents(publicSeason);
const seasonLabel = publicSeason?.season?.label ?? (season.name.includes('S2') ? 'Season 2' : 'Season 1');
const seasonMetrixUrl = publicSeason?.season?.metrixUrl ?? `https://discgolfmetrix.com/${season.id}`;
const seasonsForSwitch = seasons
  .slice()
  .sort((a, b) => seasonShortLabel(a).localeCompare(seasonShortLabel(b), 'en-AU', { numeric: true }));
const fmtCompactDate = new Intl.DateTimeFormat('en-AU', {
  weekday: 'short',
  day: 'numeric',
  month: 'short',
});
const statsViewsHtml = statsDivisionVariants()
  .map((variant) => statsViewMarkup(buildSeasonStats(variant.divisions, events, seasonLabel), variant))
  .join('');

function esc(value: unknown): string {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function isBlank(value: unknown): boolean {
  return String(value ?? '').trim() === '';
}

function dateOnlyDate(value: unknown): Date | null {
  const match = String(value || '').match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!match) return null;
  return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]), 12);
}

function resultDateLabel(value: unknown): string {
  if (isBlank(value)) return 'Date TBC';
  if (/^\d{4}-\d{2}-\d{2}$/.test(String(value))) {
    const date = dateOnlyDate(value);
    return date ? fmtCompactDate.format(date) : String(value);
  }
  return String(value);
}

function resultEventTitle(event: ResultEvent): string {
  if (!isBlank(event.name)) return String(event.name);
  if (!isBlank(event.venue)) return `${event.venue} Social Day`;
  return event.label || `Round ${event.round}`;
}

function resultEvents(resultsData: ResultsData = publicSeason): ResultEvent[] {
  const configured = Array.isArray(resultsData.events) ? resultsData.events.slice() : [];
  const byRound = new Map(configured.map((event) => [Number(event.round), event]));
  const maxRound = Math.max(15, ...configured.map((event) => Number(event.round) || 0));
  for (let round = 1; round <= maxRound; round += 1) {
    if (!byRound.has(round)) {
      configured.push({
        round,
        label: `Round ${round}`,
        status: 'needs-import',
        prizeWinners: [],
        divisions: Object.fromEntries(RESULT_DIVISIONS.map((division) => [division, []])),
      });
    }
  }
  return configured
    .filter((event) => Number(event.round) >= 1 && Number(event.round) <= maxRound)
    .sort((a, b) => Number(a.round) - Number(b.round));
}

function resultRowsForEvent(event: ResultEvent): ResultEntry[] {
  return Object.entries(event.divisions || {})
    .flatMap(([division, rows]) => (Array.isArray(rows) ? rows : [])
      .map((row) => ({ event, division, row })));
}

function allResultRows(sourceEvents = events): ResultEntry[] {
  return sourceEvents.flatMap((event) => resultRowsForEvent(event));
}

function normaliseDivision(value: unknown): string {
  const text = String(value || '').trim().toUpperCase().replace(/\s+/g, '');
  if (STATS_FILTER_DIVISIONS.includes(text)) return text;
  if (text === 'X' || text === 'Z' || text === 'X/Z' || text === 'XZ') return 'X/Z';
  return '';
}

function numberValue(value: unknown): number | null {
  if (value === null || value === undefined || value === '') return null;
  const number = Number(String(value).replace(/^\+/, ''));
  return Number.isFinite(number) ? number : null;
}

function divisionFromRating(value: unknown): string {
  const rating = numberValue(value);
  if (!Number.isFinite(rating)) return '';
  if (rating >= 890) return 'A';
  if (rating >= 845) return 'B';
  if (rating >= 790) return 'C';
  return 'D';
}

function statsDivisionForEntry(entry: ResultEntry): string {
  const importedDivision = normaliseDivision(entry.row.division || entry.division);
  if (importedDivision) return importedDivision;
  return divisionFromRating(entry.row.rating);
}

function entryMatchesStatsDivisions(entry: ResultEntry, divisions: string[] | null): boolean {
  if (!divisions || !divisions.length) return true;
  return divisions.includes(statsDivisionForEntry(entry));
}

function resultRowsForEventByStatsDivisions(event: ResultEvent, divisions: string[] | null = null): ResultEntry[] {
  return resultRowsForEvent(event).filter((entry) => entryMatchesStatsDivisions(entry, divisions));
}

function statsViewKey(divisions: string[] | null): string {
  return divisions && divisions.length ? divisions.join('-') : 'all';
}

function statsViewLabel(divisions: string[] | null): string {
  return divisions && divisions.length ? `Div ${divisions.join('/')}` : 'All Divisions';
}

function statsDivisionVariants(): StatsVariant[] {
  const variants: StatsVariant[] = [{ key: 'all', label: 'All Divisions', divisions: null }];
  const total = 1 << STATS_FILTER_DIVISIONS.length;
  for (let mask = 1; mask < total; mask += 1) {
    const divisions = STATS_FILTER_DIVISIONS.filter((_, index) => mask & (1 << index));
    variants.push({ key: statsViewKey(divisions), label: statsViewLabel(divisions), divisions });
  }
  return variants;
}

function inferPrizeDivisions(prize: PrizeRow): string[] {
  const text = `${prize?.prize || ''} ${prize?.division || ''} ${prize?.detail || ''}`.toUpperCase();
  if (/A\s*\/\s*B/.test(text)) return ['A', 'B'];
  if (/C\s*\/\s*D/.test(text)) return ['C', 'D'];
  if (/X\s*\/\s*Z|DIV\s*X|DIV\s*Z/.test(text)) return ['X/Z'];
  for (const division of STATS_FILTER_DIVISIONS) {
    if (new RegExp(`\\bDIV\\s*${division}\\b|\\b${division}\\s*HANDICAP\\b`).test(text)) return [division];
  }
  return [];
}

function playerKey(name: unknown): string {
  return String(name || '')
    .replace(/\s+\d{4,}$/, '')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
}

function cleanPlayerName(name: unknown): string {
  return String(name || '')
    .replace(/\s+\d{4,}$/, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function prizeDivisionsForEventPrize(event: ResultEvent, prize: PrizeRow): string[] {
  const key = playerKey(prize?.name);
  if (key) {
    const divisions = resultRowsForEvent(event)
      .filter((entry) => playerKey(entry.row.name) === key)
      .map((entry) => statsDivisionForEntry(entry))
      .filter(Boolean);
    if (divisions.length) return Array.from(new Set(divisions));
  }
  return inferPrizeDivisions(prize);
}

function prizeMatchesStatsDivisions(event: ResultEvent, prize: PrizeRow, divisions: string[] | null): boolean {
  if (!divisions || !divisions.length) return true;
  return prizeDivisionsForEventPrize(event, prize).some((division) => divisions.includes(division));
}

function toParValue(value: unknown): number | null {
  const text = String(value ?? '').trim();
  if (!text || /^e$/i.test(text)) return 0;
  return numberValue(text);
}

function average(values: Array<number | null>): number | null {
  const numbers = values.filter((value): value is number => Number.isFinite(value));
  if (!numbers.length) return null;
  return numbers.reduce((sum, value) => sum + value, 0) / numbers.length;
}

function formatDecimal(value: number | null, digits = 1): string {
  if (!Number.isFinite(value)) return '-';
  return Number(value).toFixed(digits).replace(/\.0$/, '');
}

function formatSigned(value: number | null): string {
  if (!Number.isFinite(value)) return '-';
  if (value === 0) return 'E';
  return value > 0 ? `+${formatDecimal(value, 1)}` : formatDecimal(value, 1);
}

function percent(value: number, total: number, digits = 1): string {
  if (!total) return '0%';
  return `${formatDecimal((value / total) * 100, digits)}%`;
}

function percentValue(value: number, total: number): number {
  return total ? (value / total) * 100 : 0;
}

function heatLevel(value: unknown, thresholds: number[]): number {
  const number = Number(value);
  if (!Number.isFinite(number)) return 0;
  let level = 0;
  for (const threshold of thresholds) {
    if (number >= threshold) level += 1;
  }
  return Math.max(1, Math.min(4, level));
}

function heatClass(kind: string, value: unknown, thresholds = [10, 20, 30, 40]): string {
  const level = heatLevel(value, thresholds);
  return level ? `heat-${kind}-${level}` : '';
}

function difficultyHeatClass(value: unknown): string {
  const number = Number(value);
  if (!Number.isFinite(number)) return '';
  if (number <= 0) return 'heat-good-4';
  if (number <= 3) return 'heat-good-2';
  if (number <= 6) return 'heat-warn-2';
  if (number <= 9) return 'heat-bad-2';
  return 'heat-bad-4';
}

function scoreBucket(scoreClass: unknown): keyof ScoreCounts {
  if (scoreClass === 'holeinone') return 'aces';
  if (scoreClass === 'eagle') return 'eagles';
  if (scoreClass === 'birdie') return 'birdies';
  if (scoreClass === 'bogey') return 'bogeys';
  if (scoreClass === 'dbogey' || scoreClass === 'fail') return 'doublePlus';
  return 'pars';
}

function emptyScoreCounts(): ScoreCounts {
  return { aces: 0, eagles: 0, birdies: 0, pars: 0, bogeys: 0, doublePlus: 0 };
}

function addScoreCounts(target: ScoreCounts, source: ScoreCounts): ScoreCounts {
  for (const key of Object.keys(target) as Array<keyof ScoreCounts>) {
    target[key] += source[key] || 0;
  }
  return target;
}

function scoreCountsForRow(row: ResultRow): ScoreCounts {
  const counts = emptyScoreCounts();
  for (const hole of row.holes || []) {
    if (isBlank(hole.score)) continue;
    counts[scoreBucket(hole.scoreClass)] += 1;
  }
  return counts;
}

function totalScores(counts: ScoreCounts): number {
  return Object.values(counts).reduce((sum, value) => sum + value, 0);
}

function scoreSummary(counts: ScoreCounts): ScoreSummary {
  const total = totalScores(counts);
  const birdieBetter = counts.aces + counts.eagles + counts.birdies;
  return {
    total,
    birdieBetter,
    birdieBetterPct: total ? (birdieBetter / total) * 100 : 0,
    parPct: total ? (counts.pars / total) * 100 : 0,
    bogeyPct: total ? (counts.bogeys / total) * 100 : 0,
    doublePlusPct: total ? (counts.doublePlus / total) * 100 : 0,
  };
}

function roundLabel(event: ResultEvent): string {
  return `Rd ${event.round}`;
}

function roundVenueLabel(event: ResultEvent): string {
  return `${roundLabel(event)} - ${event.venue || resultEventTitle(event)}`;
}

function playerDisplayName(entry: ResultEntry): string {
  return cleanPlayerName(entry.row.name);
}

function sortedByNumber(rows: ResultEntry[], valueFn: (entry: ResultEntry) => number | null, direction: 'asc' | 'desc' = 'asc'): ResultEntry[] {
  return rows
    .filter((item) => Number.isFinite(valueFn(item)))
    .slice()
    .sort((a, b) => {
      const diff = Number(valueFn(a)) - Number(valueFn(b));
      return direction === 'desc' ? -diff : diff;
    });
}

function buildSeasonStats(divisions: string[] | null = null, sourceEvents = events, currentSeasonLabel = 'Season'): SeasonStats {
  const importedEvents = sourceEvents.filter((event) => resultRowsForEventByStatsDivisions(event, divisions).length);
  const rows = allResultRows(sourceEvents).filter((entry) => entryMatchesStatsDivisions(entry, divisions));
  const totalCounts = emptyScoreCounts();
  const players = new Map<string, PlayerProfile>();
  const prizePlayers = new Map<string, PrizeProfile>();

  for (const entry of rows) {
    addScoreCounts(totalCounts, scoreCountsForRow(entry.row));
    const key = playerKey(entry.row.name);
    if (!key) continue;
    if (!players.has(key)) {
      players.set(key, {
        name: playerDisplayName(entry),
        rounds: 0,
        holes: 0,
        counts: emptyScoreCounts(),
        toPars: [],
        rawScores: [],
        summary: scoreSummary(emptyScoreCounts()),
        avgToPar: null,
        bestToPar: 0,
      });
    }
    const player = players.get(key);
    if (!player) continue;
    player.rounds += 1;
    const counts = scoreCountsForRow(entry.row);
    addScoreCounts(player.counts, counts);
    player.holes += totalScores(counts);
    const toPar = toParValue(entry.row.toPar);
    if (Number.isFinite(toPar)) player.toPars.push(Number(toPar));
    const raw = numberValue(entry.row.rawScore);
    if (Number.isFinite(raw)) player.rawScores.push(Number(raw));
  }

  for (const event of sourceEvents) {
    for (const prize of event.prizeWinners || []) {
      if (!prizeMatchesStatsDivisions(event, prize, divisions)) continue;
      const key = playerKey(prize.name);
      if (!key) continue;
      if (!prizePlayers.has(key)) {
        prizePlayers.set(key, { name: cleanPlayerName(prize.name), total: 0, ctb: 0, handicap: 0 });
      }
      const player = prizePlayers.get(key);
      if (!player) continue;
      player.total += 1;
      if (/CTB/i.test(prize.prize || '')) player.ctb += 1;
      if (/Handicap/i.test(prize.prize || '')) player.handicap += 1;
    }
  }

  const eventStats = importedEvents.map((event) => {
    const eventRows = resultRowsForEventByStatsDivisions(event, divisions);
    const counts = emptyScoreCounts();
    const toPars: number[] = [];
    const rawScores: number[] = [];
    for (const entry of eventRows) {
      addScoreCounts(counts, scoreCountsForRow(entry.row));
      const toPar = toParValue(entry.row.toPar);
      if (Number.isFinite(toPar)) toPars.push(Number(toPar));
      const raw = numberValue(entry.row.rawScore);
      if (Number.isFinite(raw)) rawScores.push(Number(raw));
    }
    const summary = scoreSummary(counts);
    return {
      event,
      players: eventRows.length,
      counts,
      summary,
      avgRaw: average(rawScores),
      avgToPar: average(toPars),
    };
  });

  const bestToPar = sortedByNumber(rows, (entry) => toParValue(entry.row.toPar), 'asc')
    .sort((a, b) => {
      const toParDiff = Number(toParValue(a.row.toPar)) - Number(toParValue(b.row.toPar));
      if (toParDiff) return toParDiff;
      return (numberValue(a.row.rawScore) ?? 999) - (numberValue(b.row.rawScore) ?? 999);
    })
    .slice(0, 10);

  const playerProfiles = Array.from(players.values())
    .filter((player) => player.rounds >= 1 && player.holes)
    .map((player) => {
      const summary = scoreSummary(player.counts);
      return {
        ...player,
        summary,
        avgToPar: average(player.toPars),
        bestToPar: Math.min(...player.toPars),
      };
    })
    .sort((a, b) => {
      if (b.rounds !== a.rounds) return b.rounds - a.rounds;
      return b.summary.birdieBetterPct - a.summary.birdieBetterPct;
    });

  const prizeBoard = Array.from(prizePlayers.values())
    .sort((a, b) => b.total - a.total || b.handicap - a.handicap || a.name.localeCompare(b.name))
    .slice(0, 12);

  return {
    events: sourceEvents,
    seasonLabel: currentSeasonLabel,
    importedEvents,
    rows,
    players,
    totalCounts,
    totalSummary: scoreSummary(totalCounts),
    eventStats,
    bestToPar,
    playerProfiles,
    playerProfilesFivePlus: playerProfiles.filter((player) => player.rounds >= 5).length,
    playerProfilesThreePlus: playerProfiles.filter((player) => player.rounds >= 3).length,
    prizeBoard,
  };
}

function statsCard(label: string, value: unknown, detail = ''): string {
  return `<article class="stats-card">
    <span>${esc(label)}</span>
    <strong>${esc(value)}</strong>
    ${detail ? `<small>${esc(detail)}</small>` : ''}
  </article>`;
}

function statsTable<T>(headers: TableHeader<T>[], rows: T[], emptyText = 'No data yet.', options: { className?: string; rowAttributes?: (row: T) => string } = {}): string {
  if (!rows.length) return `<p class="results-empty">${esc(emptyText)}</p>`;
  const className = options.className ? ` ${options.className}` : '';
  return `<div class="table-wrap stats-table-wrap${esc(className)}">
    <table data-sortable-table>
      <thead>
        <tr>${headers.map((header, index) => {
          const hasShortLabel = !isBlank(header.shortLabel) && header.shortLabel !== header.label;
          return `<th${header.className ? ` class="${esc(header.className)}"` : ''}>
          <button type="button"${hasShortLabel ? ' class="has-short-label"' : ''} data-sort-index="${index}" data-sort-type="${esc(header.sortType || 'text')}">
            <span class="label-full">${esc(header.label)}</span>${hasShortLabel ? `<span class="label-short">${esc(header.shortLabel)}</span>` : ''}<span class="sort-indicator" aria-hidden="true"></span>
          </button>
        </th>`;
        }).join('')}</tr>
      </thead>
      <tbody>
        ${rows.map((row) => {
          const rowAttributes = typeof options.rowAttributes === 'function' ? options.rowAttributes(row) : '';
          return `<tr${rowAttributes ? ` ${rowAttributes}` : ''}>${headers.map((header) => {
            const value = header.value(row);
            const sortValue = typeof header.sortValue === 'function' ? header.sortValue(row) : value;
            const cellClass = typeof header.cellClass === 'function' ? header.cellClass(row) : header.cellClass || '';
            return `<td${cellClass ? ` class="${esc(cellClass)}"` : ''} data-sort-value="${esc(sortValue ?? '')}">${esc(value)}</td>`;
          }).join('')}</tr>`;
        }).join('')}
      </tbody>
    </table>
  </div>`;
}

function scoreMixBlock(counts: ScoreCounts): string {
  const total = totalScores(counts);
  const buckets: Array<[keyof ScoreCounts, string, string]> = [
    ['aces', 'Aces', 'mix-aces'],
    ['eagles', 'Eagles', 'mix-eagles'],
    ['birdies', 'Birdies', 'mix-birdies'],
    ['pars', 'Pars', 'mix-pars'],
    ['bogeys', 'Bogeys', 'mix-bogeys'],
    ['doublePlus', 'Double+', 'mix-double-plus'],
  ];
  const segments = buckets
    .filter(([key]) => counts[key] > 0)
    .map(([key, label, className]) => {
      const width = Math.max(1.5, (counts[key] / total) * 100);
      return `<span class="score-mix-segment ${className}" style="width:${width.toFixed(2)}%" title="${esc(label)}: ${esc(percent(counts[key], total))}"></span>`;
    }).join('');
  const legend = buckets.map(([key, label, className]) => `
    <div class="score-mix-pill ${className}">
      <strong>${esc(label)}</strong>
      <em>${esc(percent(counts[key], total))}</em>
      <small>${esc(counts[key].toLocaleString('en-AU'))}</small>
    </div>`).join('');
  return `<div class="score-mix">
    <div class="score-mix-bar" aria-label="Season scoring mix">${segments}</div>
    <div class="score-mix-grid">${legend}</div>
  </div>`;
}

function attendanceChart(eventStats: EventStats[]): string {
  const maxPlayers = Math.max(1, ...eventStats.map((item) => item.players));
  return `<div class="attendance-chart">
    ${eventStats.map((item) => {
      const width = (item.players / maxPlayers) * 100;
      return `<div class="attendance-row">
        <span>${esc(roundLabel(item.event))}</span>
        <div><i style="width:${width.toFixed(2)}%"></i></div>
        <strong>${esc(item.players)}</strong>
        <small>${esc(item.event.venue || '')}</small>
      </div>`;
    }).join('')}
  </div>`;
}

function topRoundRows(entries: ResultEntry[]): Array<Record<string, unknown>> {
  return entries.map((entry) => ({
    player: playerDisplayName(entry),
    event: roundVenueLabel(entry.event),
    toPar: formatSigned(toParValue(entry.row.toPar)),
    toParValue: toParValue(entry.row.toPar),
    raw: numberValue(entry.row.rawScore),
    rating: numberValue(entry.row.rating),
    division: statsDivisionForEntry(entry) || entry.row.division || entry.division,
  }));
}

function profileFilterControl(): string {
  return `<label class="profile-filter">
    <span>Show</span>
    <select data-profile-min>
      <option value="5" selected>5+ days</option>
      <option value="3">3+ days</option>
      <option value="1">All players</option>
    </select>
  </label>`;
}

function profileRowAttributes(row: PlayerProfile): string {
  return `data-profile-row data-profile-rounds="${esc(row.rounds)}"${row.rounds < 5 ? ' hidden' : ''}`;
}

function statsViewMarkup(stats: SeasonStats, variant: StatsVariant): string {
  const totalPlayers = stats.players.size;
  const totalRounds = stats.rows.length;
  const totalHoles = stats.totalSummary.total;
  const avgField = stats.importedEvents.length ? totalRounds / stats.importedEvents.length : 0;
  const topAttendance = stats.eventStats.slice().sort((a, b) => b.players - a.players)[0];
  const easiestEvent = stats.eventStats.slice().sort((a, b) => (a.avgToPar ?? 999) - (b.avgToPar ?? 999))[0];
  const toughestEvent = stats.eventStats.slice().sort((a, b) => (b.avgToPar ?? -999) - (a.avgToPar ?? -999))[0];
  const importedSummary = stats.importedEvents.length
    ? `${stats.importedEvents.length} imported rounds from ${resultDateLabel(stats.importedEvents[0]?.date)} to ${resultDateLabel(stats.importedEvents.at(-1)?.date)}.`
    : `No imported rounds for ${variant.label} yet.`;

  return `<div class="stats-view" data-stats-view="${esc(variant.key)}"${variant.key === 'all' ? '' : ' hidden'}>
  <section class="stats-overview-band">
    <div class="section-head compact-section-head">
