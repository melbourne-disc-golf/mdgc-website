---
import { Temporal } from '@js-temporal/polyfill';
import type { CalendarEvent } from '@utils/events';

interface Props {
  events: CalendarEvent[];
  maxDaysInPast?: number;
  maxDaysInFuture?: number;
  weekStartDay?: number; // 1=Mon ... 7=Sun (ISO weekday)
}

const { events, maxDaysInPast, maxDaysInFuture, weekStartDay = 4 } = Astro.props;

const SHORT_MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function getEventSourceClass(event: CalendarEvent): string {
  return `event-${event.source || 'other'}`;
}

const today = Temporal.Now.plainDateISO();

const minDateLimit = maxDaysInPast !== undefined
  ? today.subtract({ days: maxDaysInPast })
  : undefined;
const maxDateLimit = maxDaysInFuture !== undefined
  ? today.add({ days: maxDaysInFuture })
  : undefined;

const cmp = Temporal.PlainDate.compare;

const filteredEvents = events.filter((e) => {
  if (minDateLimit && cmp(e.startDate, minDateLimit) < 0) return false;
  if (maxDateLimit && cmp(e.startDate, maxDateLimit) > 0) return false;
  return true;
});

const sortedEvents = [...filteredEvents].sort((a, b) => cmp(a.startDate, b.startDate));
const minDate = sortedEvents.length > 0 ? sortedEvents[0].startDate : today;
const maxDate = sortedEvents.length > 0 ? sortedEvents[sortedEvents.length - 1].startDate : today;

// Map each date (as ISO string) to its events, expanding multi-day events
const eventsByDate = new Map<string, CalendarEvent[]>();
for (const event of filteredEvents) {
  const end = event.endDate || event.startDate;
  let current = event.startDate;
  while (cmp(current, end) <= 0) {
    const key = current.toString();
    const existing = eventsByDate.get(key) || [];
    existing.push(event);
    eventsByDate.set(key, existing);
    current = current.add({ days: 1 });
  }
}

type DayCell = {
  date: Temporal.PlainDate;
  isToday: boolean;
  isWeekend: boolean;
  isPast: boolean;
  events: CalendarEvent[];
};

function getWeekStart(date: Temporal.PlainDate): Temporal.PlainDate {
  // dayOfWeek: 1=Mon .. 7=Sun; weekStartDay uses same convention
  const offset = (date.dayOfWeek - weekStartDay + 7) % 7;
  return date.subtract({ days: offset });
}

function getWeekEnd(date: Temporal.PlainDate): Temporal.PlainDate {
  const offset = (date.dayOfWeek - weekStartDay + 7) % 7;
  return date.add({ days: 6 - offset });
}

function buildGrid(): DayCell[] {
  const cells: DayCell[] = [];
  const gridStart = getWeekStart(minDate);
  const gridEnd = getWeekEnd(maxDate);

  let current = gridStart;
  while (cmp(current, gridEnd) <= 0) {
    const key = current.toString();
    const dow = current.dayOfWeek;
    cells.push({
      date: current,
      isToday: cmp(current, today) === 0,
      isWeekend: dow === 6 || dow === 7,
      isPast: cmp(current, today) < 0,
      events: eventsByDate.get(key) || [],
    });
    current = current.add({ days: 1 });
  }

  return cells;
}

function getDayCellClasses(cell: DayCell): string {
  const classes = ['day-cell'];
  if (cell.isWeekend) classes.push('weekend');
  return classes.join(' ');
}

// ISO weekdays: 1=Mon .. 7=Sun
const allDays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
const weekdays = Array.from({ length: 7 }, (_, i) => allDays[(weekStartDay - 1 + i) % 7]);

// Compute which column indices are weekends
const weekendColumns = weekdays
  .map((day, i) => (day === 'Sat' || day === 'Sun' ? i : -1))
  .filter((i) => i >= 0);
const gridColumns = Array.from({ length: 7 }, (_, i) => (weekendColumns.includes(i) ? '1.3fr' : '1fr')).join(' ');
const grid = buildGrid();
---

<div class="month-calendar">
  <div class="calendar-grid" style={`grid-template-columns: ${gridColumns};`}>
    {weekdays.map((day) => (
      <div class="weekday-header">{day}</div>
    ))}
    {grid.map((cell) => {
      const visibleEvents = cell.events.slice(0, 3);
      const moreCount = cell.events.length - 3;
      return (
        <div class={getDayCellClasses(cell)} data-date={cell.date.toString()}>
          <div class="day-header">
            <span class="day-number">
              {cell.date.day}
            </span>
            <span class="month-label">{SHORT_MONTHS[cell.date.month - 1]}</span>
          </div>
          <div class="day-events">
            {visibleEvents.map((event) =>
              event.url ? (
                <a href={event.url} class={`event-chip ${getEventSourceClass(event)}`} title={event.summary} data-location={event.location || ''}>
                  <span class="event-summary">{event.summary}</span>
                </a>
              ) : (
                <div class={`event-chip ${getEventSourceClass(event)}`} title={event.summary} data-location={event.location || ''}>
                  <span class="event-summary">{event.summary}</span>
                </div>
              )
            )}
            {moreCount > 0 && <div class="more-events">+{moreCount} more</div>}
          </div>
        </div>
      );
    })}
  </div>
</div>

<style>
  .month-calendar {
    margin: 1rem 0;
    overflow-x: auto;
  }

  .calendar-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border, #e5e5e5);
    border: 1px solid var(--color-border, #e5e5e5);
    min-width: 500px;
  }

  .weekday-header {
    background: var(--color-bg-muted, #f9fafb);
    padding: 0.5rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
  }

  .day-cell {
    background: white;
    min-height: 80px;
    min-width: 0;
    padding: 0.25rem;
    display: flex;
    flex-direction: column;
  }

  .day-cell.past {
    background: var(--color-bg-muted, #f9fafb);
    opacity: 0.6;
  }

  .day-cell.weekend {
    background: #f0fdf4;
  }

  .day-header {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.25rem;
  }

  .day-number {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text, #111827);
  }

  .day-number.today {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--color-primary, #3b82f6);
    color: white;
    border-radius: 50%;
    font-weight: 600;
  }

  .month-label {
    font-size: 0.75rem;
    color: var(--color-text-muted, #6b7280);
    font-weight: 400;
  }

  .day-events {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .event-chip {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 2px 4px;
    border-radius: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
    border-style: solid;
    border-width: 0px;
    border-left-width: 2px;
  }

  .event-chip.event-club {
    background: #dbeafe;
    border-color: #3b82f6;
  }

  .event-chip.event-social {
    background: #fef9c3;
    border-color: #eab308;
  }

  .event-chip.event-external {
    background: #f3f4f6;
    border-color: #9ca3af;
  }

  .event-chip.event-other {
    background: #f3f4f6;
    border-color: #d1d5db;
  }

  .event-chip.expanded {
    position: fixed;
    z-index: 100;
    border-width: 1px 3px;
    min-width: 200px;
    max-width: 280px;
    white-space: normal;
    word-wrap: break-word;
    overflow: visible;
    text-overflow: clip;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    font-size: 0.9rem;
    transition: opacity 0.2s ease-out;
  }

  .event-chip.expanded.fading {
    opacity: 0;
  }

  a.event-chip.expanded .event-summary {
    text-decoration: underline;
  }

  :global(.event-chip.expanded .event-location) {
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
    margin-top: 0.25rem;
    font-weight: 300;
  }

  .more-events {
    font-size: 0.7rem;
    color: var(--color-text-muted, #6b7280);
    padding: 2px 4px;
  }

  @media (max-width: 640px) {
    .day-cell {
      min-height: 60px;
      padding: 0.125rem;
    }

    .day-number {
      font-size: 0.75rem;
    }

    .day-number.today {
      width: 1.25rem;
      height: 1.25rem;
      font-size: 0.75rem;
    }

    .month-label {
      font-size: 0.65rem;
    }

    .event-chip {
      font-size: 0.6rem;
      padding: 1px 2px;
    }

    .weekday-header {
      font-size: 0.75rem;
      padding: 0.25rem;
    }
  }
</style>

<script>
  // Highlight today and grey out past dates dynamically
  const today = new Date();
  const todayStr = today.toLocaleDateString('en-CA', { timeZone: 'Australia/Melbourne' });
  
  document.querySelectorAll('.day-cell[data-date]').forEach((cell) => {
    const cellDate = cell.getAttribute('data-date')!;
    if (cellDate === todayStr) {
      cell.classList.add('today');
      cell.querySelector('.day-number')?.classList.add('today');
    } else if (cellDate < todayStr) {
      cell.classList.add('past');
    }
  });

  let expandedChip: HTMLElement | null = null;

  function collapseAll() {
    if (expandedChip) {
      const chip = expandedChip;
      expandedChip = null;
      chip.classList.add('fading');
      chip.addEventListener('transitionend', () => chip.remove(), { once: true });
    }
  }

  window.addEventListener('scroll', collapseAll);

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    
    if (expandedChip?.contains(target)) {
      return;
    }
    
    collapseAll();
    
    const chip = target.closest('.event-chip') as HTMLElement | null;
    if (!chip) {
      return;
    }

    e.preventDefault();
    
    const rect = chip.getBoundingClientRect();
    const viewportMid = window.innerWidth / 2;

    expandedChip = chip.cloneNode(true) as HTMLElement;
    expandedChip.classList.add('expanded');

    // Add location if available
    const location = chip.getAttribute('data-location');
    if (location) {
      const locationEl = document.createElement('div');
      locationEl.className = 'event-location';
      locationEl.textContent = location;
      expandedChip.appendChild(locationEl);
    }

    expandedChip.style.top = `${rect.top}px`;
    if (rect.left < viewportMid) {
      expandedChip.style.left = `${rect.left}px`;
    } else {
      expandedChip.style.right = `${window.innerWidth - rect.right}px`;
    }
    document.body.appendChild(expandedChip);
  });
</script>
