---
import { Icon } from 'astro-icon/components';
import logoImage from '@images/mdgc-logo.png';
import { type NavItem } from '@data/navigation.ts';
import { isActiveNavItem, navItemColor } from '@utils/nav';
import { isExternal, externalLinkAttrs } from '@utils/links';

export interface Props {
	navItems: NavItem[];
	currentPath: string;
}

const { navItems, currentPath } = Astro.props;
---

<header class="sticky top-0 z-2000">
	<div id="menu-strip" class="relative bg-linear-to-r from-black to-mdgc-blue-dark text-white will-change-transform">
		<div id="menu-content" class="content-width flex items-center h-18 space-x-8">
			<div id="menu-logo" class="flex items-center gap-3">
				<a href="/" title="Home" class="logo-link flex items-center gap-3">
					<img src={logoImage.src} alt="" class="h-12 w-auto" />
					<span class="text-sm lg:text-base font-display">Melbourne Disc Golf Club</span>
				</a>
			</div>

			<div id="menu-links" class="mx-auto">
				<nav class="hidden md:flex items-center space-x-4">
					{navItems.map(item => (
						item.subPages ? (
							<div class="relative group">
								<div class="flex items-center">
									<a href={item.href} class={`${navItemColor(currentPath, item.href)} hover:text-white transition-colors text-sm lg:text-base px-4 py-2 rounded-lg border border-mdgc-blue-light/25 relative z-1001 group-hover:bg-gray-900 group-hover:text-mdgc-blue-light group-hover:rounded-b-none group-hover:border-b-transparent`}>{item.title}</a>
								</div>
								<div data-subnav class="absolute left-0 top-full -mt-px w-max min-w-full rounded-b-lg rounded-tr-lg border border-mdgc-blue-light/25 bg-gray-900 p-1.5 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-1000">
									{item.subPages.map(subItem => {
										const isActive = isActiveNavItem(currentPath, subItem.href);
										return (
											<a href={subItem.href} class={`block rounded-md px-5 py-1 text-sm transition-colors whitespace-nowrap text-mdgc-blue-light ${isActive ? 'bg-white/15 text-white' : 'hover:bg-mdgc-blue-dark hover:text-white'}`}>{subItem.title}</a>
										);
									})}
								</div>
							</div>
						) : (
							<a href={item.href} class={`${navItemColor(currentPath, item.href)} hover:text-white transition-colors text-sm lg:text-base px-4 py-2 rounded-lg border border-mdgc-blue-light/25 hover:bg-gray-900`} {...externalLinkAttrs(item.href)}>{item.title}{isExternal(item.href) && ' ↗'}</a>
						)
					))}
				</nav>
			</div>

			<!-- Mobile menu button -->
			<div class="md:hidden ml-auto">
				<button id="mobile-menu-button" class="text-mdgc-blue-light hover:text-white" aria-label="Toggle mobile menu">
					<Icon name="heroicons:bars-3" class="h-6 w-6" />
				</button>
			</div>
		</div>

		<!-- Mobile menu — a drop-down that expands over the content below (not in flow),
		     collapsing via a grid-rows 0fr↔1fr transition (see .is-open). -->
		<div id="mobile-menu" class="md:hidden absolute inset-x-0 top-full bg-linear-to-r from-black to-mdgc-blue-dark shadow-xl grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out">
			<div class="overflow-hidden">
			<nav class="px-2 pt-2 pb-3 space-y-1">
				{navItems.map(item => (
					item.subPages ? (
						<div>
							<a href={item.href} class={`block px-3 py-2 hover:bg-mdgc-blue-dark rounded-md font-semibold ${navItemColor(currentPath, item.href)} hover:text-white transition-colors`}>{item.title}</a>
							{item.subPages.map(subItem => (
								<a href={subItem.href} class={`block px-6 py-1 text-sm rounded-md ${navItemColor(currentPath, subItem.href)} transition-colors ${isActiveNavItem(currentPath, subItem.href) ? 'bg-white/15' : 'hover:bg-mdgc-blue-dark hover:text-white'}`}>{subItem.title}</a>
							))}
						</div>
					) : (
						<a href={item.href} class={`block px-3 py-2 hover:bg-mdgc-blue-dark rounded-md ${navItemColor(currentPath, item.href)} hover:text-white transition-colors`} {...externalLinkAttrs(item.href)}>{item.title}{isExternal(item.href) && ' ↗'}</a>
					)
				))}
			</nav>
			</div>
		</div>
	</div>
</header>

<style>
	/* Nav/dropdown/mobile links shouldn't use the global link zoom — it grows the tab background. */
	#menu-links a:hover,
	#mobile-menu a:hover {
		transform: none;
	}

	/* When the bar is scrolled out of frame, don't let a hovered sub-nav linger on screen. */
	#menu-strip.is-hidden [data-subnav] {
		opacity: 0;
		visibility: hidden;
	}

	#mobile-menu.is-open {
		grid-template-rows: 1fr;
	}
</style>

<script>
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');

	// "Headroom" behaviour: the strip is locked to a virtual position between fully
	// in-frame and fully out-of-frame, and moves with the content as you scroll —
	// scroll down and it slides up out of view, scroll up and it slides back in,
	// always at the same rate as the page. An open mobile menu folds away as soon as
	// you scroll down, so it gets out of the way rather than scrolling along.
	const menuStrip = document.getElementById('menu-strip');
	let lastScrollY = Math.max(0, window.scrollY);
	let offset = 0; // px the strip is translated up, clamped to [0, strip height]

	const onScroll = () => {
		// Clamp to the scrollable range: iOS Safari reports overscroll while rubber-banding
		// (negative past the top, beyond max at the bottom). Fed into the delta below, the
		// bounce-back reads as a scroll and strands the bar part-way — a gap under it at the top.
		const doc = document.documentElement;
		const maxScrollY = Math.max(0, doc.scrollHeight - doc.clientHeight);
		const currentScrollY = Math.min(Math.max(window.scrollY, 0), maxScrollY);

		if (currentScrollY > lastScrollY) mobileMenu?.classList.remove('is-open');

		const stripHeight = menuStrip?.offsetHeight ?? 0;
		offset = Math.min(Math.max(offset + currentScrollY - lastScrollY, 0), stripHeight);
		if (menuStrip) menuStrip.style.transform = `translateY(${-offset}px)`;
		menuStrip?.classList.toggle('is-hidden', stripHeight > 0 && offset >= stripHeight);

		lastScrollY = currentScrollY;
	};

	window.addEventListener('scroll', onScroll, { passive: true });

	mobileMenuButton?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('is-open');
	});
</script>
