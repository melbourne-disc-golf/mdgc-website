---
import { Icon } from 'astro-icon/components';

interface Props {
	href: string;
	title: string;
	description?: string;
	icon?: string;
	image?: string;
	class?: string;
}

const { href, title, description, icon, image, class: className = '' } = Astro.props;
---

<a href={href} class={`link-panel not-prose ${className}`}>
	<div class="link-panel-inner">
		<div class="link-panel-icon">
			{icon && <Icon name={icon} size={58} />}
			{image && <img src={image} alt={`${title} logo`} />}
		</div>
		<div class="link-panel-content">
			<h3>{title}</h3>
			{description && <p>{description}</p>}
		</div>
	</div>
</a>

<style>
	.link-panel {
		text-decoration: none;
		color: inherit;
		display: block;
		cursor: pointer;
		height: 100%;
	}

	.link-panel-inner {
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
		background-color: #ffffff;
		border: 1px solid rgba(6, 61, 99, 0.16);
		border-radius: 0.5rem;
		padding: 1.5rem;
		transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
		height: 100%;
		box-shadow: 0 12px 30px rgba(6, 61, 99, 0.09);
	}

	.link-panel-inner::after {
		content: "";
		position: absolute;
		inset-inline: 0;
		bottom: 0;
		height: 4px;
		background: linear-gradient(90deg, var(--color-mdgc-amber), var(--color-mdgc-accent), var(--color-mdgc-blue));
	}

	.link-panel:hover .link-panel-inner {
		background-color: #ffffff;
		border-color: var(--color-mdgc-accent);
		box-shadow: 0 14px 30px rgba(6, 61, 99, 0.12);
		transform: translateY(-2px);
	}

	.link-panel:hover .link-panel-icon {
		color: var(--color-mdgc-accent-deep);
	}

	.link-panel-icon {
		flex-shrink: 0;
		color: var(--color-mdgc-accent);
		transition: all 0.2s;
	}

	.link-panel-icon img {
		width: 58px;
		height: 58px;
		object-fit: contain;
	}

	.link-panel-content {
		flex-grow: 1;
		text-align: left;
	}

	.link-panel h3 {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 900;
		line-height: 1.05;
		margin: 0 0 0.25rem 0;
		color: var(--color-mdgc-ink);
	}

	.link-panel p {
		color: var(--color-text-body);
		font-size: 0.92rem;
		line-height: 1.5;
		margin: 0;
	}
</style>
