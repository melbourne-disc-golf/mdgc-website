---
import { Icon } from 'astro-icon/components';
import { isExternal, externalLinkAttrs } from '@utils/links';

interface Props {
	href: string;
	title: string;
	description?: string;
	icon?: string;
	image?: string;
	class?: string;
}

const { href, title, description, icon, image, class: className = '' } = Astro.props;

const external = isExternal(href);
---

<a href={href} class={`link-panel not-prose ${className}`} {...externalLinkAttrs(href)}>
	<div class="link-panel-inner">
		{external && (
			<span class="link-panel-external" aria-hidden="true">
				<Icon name="heroicons:arrow-up-right" size={18} />
			</span>
		)}
		<div class="link-panel-icon">
			{icon && <Icon name={icon} size={58} />}
			{image && <img src={image} alt={`${title} logo`} />}
		</div>
		<div class="link-panel-content">
			<h3>{title}{external && <span class="sr-only"> (opens in a new tab)</span>}</h3>
			{description && <p>{description}</p>}
		</div>
	</div>
</a>

<style>
	.link-panel {
		text-decoration: none;
		color: inherit;
		display: block;
		cursor: pointer;
		height: 100%;
	}

	.link-panel-inner {
		position: relative;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
		background-color: #ffffff;
		/* faint blue border at rest, ramping to full mdgc-blue-dark on hover */
		border: 1px solid color-mix(in srgb, var(--color-mdgc-blue-dark), transparent 70%);
		border-radius: 0.5rem;
		padding: 1.5rem;
		transition: all 0.2s;
		height: 100%;
		box-shadow: var(--panel-shadow);
	}

	.link-panel-external {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		color: #9ca3af;
		transition: color 0.2s, transform 0.2s;
	}

	.link-panel:hover .link-panel-external {
		color: var(--color-mdgc-blue-dark);
		transform: translate(1px, -1px);
	}

	.link-panel:hover .link-panel-inner {
		border-color: var(--color-mdgc-blue-dark);
		box-shadow: var(--panel-shadow-hover);
	}

	.link-panel:hover h3 {
		color: var(--color-mdgc-blue-dark);
	}

	.link-panel:hover .link-panel-icon {
		color: var(--color-mdgc-blue-dark);
	}

	.link-panel-icon {
		flex-shrink: 0;
		color: var(--color-mdgc-blue);
		transition: all 0.2s;
	}

	.link-panel-icon img {
		width: 58px;
		height: 58px;
		object-fit: contain;
	}

	.link-panel-content {
		flex-grow: 1;
		text-align: left;
	}

	.link-panel h3 {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 0.25rem 0;
		color: #1f2937;
		transition: color 0.2s;
	}

	.link-panel p {
		color: #6b7280;
		font-size: 0.875rem;
		margin: 0;
	}
</style>
