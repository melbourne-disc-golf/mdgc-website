---
import { Icon } from 'astro-icon/components';
import logoImage from '@images/mdgc-logo.png';
import ReportIssue from '@components/ReportIssue.astro';
import { type NavItem } from '@data/navigation.ts';
import { navItemColor } from '@utils/nav';
import { isExternal, externalLinkAttrs } from '@utils/links';

export interface Props {
	navItems: NavItem[];
	currentPath: string;
	cmsPath?: string;
}

const { navItems, currentPath, cmsPath } = Astro.props;

const githubUrl = 'https://github.com/melbourne-disc-golf/mdgc-website';
const cmsUrl = cmsPath ? `/cms/sveltia#${cmsPath}` : null;
---

<footer class="bg-gray-900 text-white sm:px-6 lg:px-8 py-12 mt-auto">
	<div class="no-print content-width flex flex-row gap-8">

		<!-- Logo section -->
		<div class="shrink-0">
			<a href="/" title="Home" class="logo-link">
				<img src={logoImage.src} alt="Melbourne Disc Golf Club" class="h-12 sm:h-16 w-auto" />
			</a>
		</div>

		<!-- Navigation sections grid -->
		<nav class="flex flex-wrap mx-auto gap-4 sm:gap-6 md:gap-8 lg:gap-16 items-start">
			{navItems.map((section) => (
				<div>
					<h3 class="font-semibold mb-2">
						<a href={section.href} class={`inline-flex items-center gap-1 ${navItemColor(currentPath, section.href)} whitespace-nowrap hover:text-white hover:underline transition-colors`} {...externalLinkAttrs(section.href)}>
							{section.icon && <Icon name={section.icon} class="w-4 h-4" />}
							{section.title}{isExternal(section.href) && ' ↗'}
						</a>
					</h3>
					{section.subPages && (
						<ul class="space-y-0.5 hidden md:block pl-2">
							{section.subPages.map(link => (
								<li>
									<a href={link.href} class={`inline-block text-sm ${navItemColor(currentPath, link.href)} hover:text-white hover:underline transition-colors`} {...externalLinkAttrs(link.href)}>
										{link.title}{isExternal(link.href) && ' ↗'}
									</a>
								</li>
							))}
						</ul>
					)}
				</div>
			))}
		</nav>

	</div>

	<!-- Bottom section -->
	<div class="border-t border-slate-700 mt-8 pt-2 flex flex-col md:flex-row justify-between items-center gap-4">
		<div class="text-slate-400 text-sm text-center md:text-left">
			<p>© {new Date().getFullYear()} Melbourne Disc Golf Club. All rights reserved.</p>
			<p class="text-xs text-slate-500 mt-1">last updated: {new Date().toLocaleString('en-AU', { timeZone: 'Australia/Melbourne', dateStyle: 'medium', timeStyle: 'short' })}</p>
		</div>
		<div class="no-print flex items-center gap-4">
			{cmsUrl && (
				<a href={cmsUrl} target="_blank" rel="noopener noreferrer" class="inline-block text-slate-400 hover:text-white transition-colors" aria-label="Edit page in CMS" title="Edit in CMS">
					<Icon name="mdi:pencil" class="h-5 w-5" />
				</a>
			)}
			<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-block text-slate-400 hover:text-white transition-colors" aria-label="View source on GitHub" title="View source on GitHub">
				<Icon name="mdi:github" class="h-5 w-5" />
			</a>
			<ReportIssue />
		</div>
	</div>

</footer>
