---
import s1ResultsData from '@data/social-results/s1.json';
import s2ResultsData from '@data/social-results/s2.json';
import type { EventDetail, Season } from '@utils/metrix';
import { getEvent } from '@utils/metrix';

interface Props {
  season: Season;
  seasons: Season[];
  baseHref?: string;
  defaultSeasonId?: number;
}

interface PrizeRow {
  prize?: string;
  name?: string;
  detail?: string;
  division?: string;
  hole?: string | number;
  note?: string;
}

interface ResultHole {
  hole?: string | number;
  score?: string | number | null;
  scoreClass?: string;
}

type PublicResultRow = Record<string, unknown> & {
  holes?: ResultHole[];
};

interface PublicResultEvent {
  round: string | number;
  label?: string;
  name?: string;
  date?: string;
  venue?: string;
  metrixId?: string | number;
  status?: string;
  prizeWinners?: PrizeRow[];
  prizeEmailRows?: PrizeRow[];
  prizes?: PrizeRow[];
  prizeNotes?: string[];
  handicapLeaders?: PrizeRow[];
  divisions?: Record<string, PublicResultRow[]>;
}

interface PublicResultsData {
  season?: {
    label?: string;
    name?: string;
    metrixId?: string | number;
    metrixUrl?: string;
    sourceName?: string;
  };
  events?: PublicResultEvent[];
}

interface DisplayHole {
  hole: number;
  score: string;
  scoreClass: string;
}

interface DisplayRow {
  position: string;
  name: string;
  rating: string;
  toPar: string;
  holes: DisplayHole[];
  rawScore: string;
  handicap: string;
  net: string;
}

interface DisplayDivision {
  label: string;
  rows: DisplayRow[];
  holeHeaders: number[];
}

const { season, seasons, baseHref = '/events/social/results', defaultSeasonId = season.id } = Astro.props;
const publicResultsData = [s1ResultsData, s2ResultsData] as PublicResultsData[];
const publicSeason = publicResultsData.find((data) => String(data.season?.metrixId ?? '') === String(season.id));
const publicEventsByMetrixId = new Map(
  (publicSeason?.events ?? [])
    .filter((event) => event.metrixId !== undefined && event.metrixId !== null)
    .map((event) => [String(event.metrixId), event])
);
const publicEventsByRound = new Map(
  (publicSeason?.events ?? []).map((event) => [Number(event.round), event])
);

const rounds = season.rounds.map((round) => ({
  ...round,
  detail: round.played ? getEvent(round.id) : null,
  resultEvent: publicEventsByMetrixId.get(String(round.id)) ?? publicEventsByRound.get(round.round) ?? null,
}));

const defaultIndex = (() => {
  for (let index = rounds.length - 1; index >= 0; index -= 1) {
    if (resultEventImported(rounds[index])) return index;
  }
  return 0;
})();

const playedCount = rounds.filter((round) => resultEventImported(round)).length;
const seasonLabel = publicSeason?.season?.label ?? (season.name.includes('S2') ? 'Season 2' : 'Season 1');

function seasonShortLabel(value: Season): string {
  if (value.name.includes('S2')) return 'S2';
  if (value.name.includes('S1')) return 'S1';
  if (/MDGC\s+2026\s+Social\s+Days$/i.test(value.name.trim())) return 'S1';
  const match = value.name.match(/Season\s+(\d+)/i);
  return match ? `S${match[1]}` : String(value.id);
}

function seasonHref(value: Season): string {
  return value.id === defaultSeasonId ? baseHref : `${baseHref}/${value.id}`;
}

function tabId(round: { round: number }): string {
  return `social-results-${season.id}-rd-${String(round.round).padStart(2, '0')}`;
}

function formatShortDate(date: string): string {
  const d = new Date(date);
  return d.toLocaleDateString('en-AU', { day: 'numeric', month: 'numeric' });
}

function formatLongDate(date: string): string {
  const d = new Date(date);
  return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
}

function courseTitle(round: { courseName: string; name: string }): string {
  const source = round.courseName.includes('&rarr;') ? round.name : round.courseName;
  const cleaned = source
    .replace(/&rarr;/g, '->')
    .split('->')
    .pop()
    ?.trim();
  if (cleaned && cleaned !== '1') return cleaned;
  return round.name.split('-').pop()?.trim() || round.name;
}

function formatDiff(diff: number): string {
  return diff > 0 ? `+${diff}` : String(diff);
}

function fmt2(n: number | null): string {
  return n === null ? '-' : n.toFixed(2);
}

function metrixHoleScoreClass(score: number | null, holePar: number): string {
  if (score === null) return 'score-cell';
  if (score === 1) return 'score-cell score-holeinone';
  const diff = score - holePar;
  if (diff <= -2) return 'score-cell score-eagle';
  if (diff === -1) return 'score-cell score-birdie';
  if (diff === 1) return 'score-cell score-bogey';
  if (diff >= 2) return 'score-cell score-dbogey';
  return 'score-cell';
}

function isBlank(value: unknown): boolean {
  return value === undefined || value === null || String(value).trim() === '';
}

function valueAsString(value: unknown): string {
  return isBlank(value) ? '' : String(value);
}

function rowValue(row: PublicResultRow, keys: string[]): string {
  for (const key of keys) {
    if (!isBlank(row[key])) return valueAsString(row[key]);
  }
  return '';
}

function prizeRowsForResultEvent(event: PublicResultEvent | null): PrizeRow[] {
  if (!event) return [];
  return (event.prizeWinners || event.prizeEmailRows || event.prizes || [])
    .filter((row) => !isBlank(row.prize) || !isBlank(row.name));
}

function prizeDisplayOrder(row: PrizeRow): number {
  if (/Handicap/i.test(row.prize || '')) return 0;
  if (/CTB/i.test(row.prize || '')) return 1;
  return 2;
}

function displayedPrizeRowsForResultEvent(event: PublicResultEvent | null): PrizeRow[] {
  return prizeRowsForResultEvent(event)
    .map((row, index) => ({ row, index }))
    .sort((a, b) => prizeDisplayOrder(a.row) - prizeDisplayOrder(b.row) || a.index - b.index)
    .map((item) => item.row);
}

function prizeNotesForResultEvent(event: PublicResultEvent | null): string[] {
  return (event?.prizeNotes ?? [])
    .map((note) => String(note || '').trim())
    .filter(Boolean);
}

function resultPrizeDetail(row: PrizeRow): string {
  return valueAsString(row.detail || row.division || row.hole || row.note);
}

function resultPrizeKind(row: PrizeRow): 'ctb' | 'handicap' {
  return /CTB/i.test(row.prize || '') ? 'ctb' : 'handicap';
}

function publicDivisionKeys(event: PublicResultEvent | null): string[] {
  const divisions = event?.divisions ?? {};
  const rank = ['A', 'B', 'C', 'D', 'X/Z', 'X', 'Z'];
  return Object.keys(divisions)
    .filter((key) => (divisions[key] ?? []).length > 0)
    .sort((a, b) => {
      const ai = rank.indexOf(a);
      const bi = rank.indexOf(b);
      return (ai === -1 ? rank.length : ai) - (bi === -1 ? rank.length : bi) || a.localeCompare(b);
    });
}

function resultEventImported(round: { detail: EventDetail | null; resultEvent?: PublicResultEvent | null }): boolean {
  const resultEvent = round.resultEvent ?? null;
  return displayedPrizeRowsForResultEvent(resultEvent).length > 0
    || (resultEvent?.handicapLeaders ?? []).length > 0
    || publicDivisionKeys(resultEvent).length > 0
    || round.detail !== null;
}

function panelTitle(round: { courseName: string; name: string; resultEvent?: PublicResultEvent | null }): string {
  return round.resultEvent?.venue || courseTitle(round);
}

function panelEventTitle(round: { name: string; resultEvent?: PublicResultEvent | null }): string {
  return round.resultEvent?.name || round.name;
}

function panelDate(round: { date: string; resultEvent?: PublicResultEvent | null }): string {
  return round.resultEvent?.date || round.date;
}

function publicDisplayRow(row: PublicResultRow): DisplayRow {
  const holes = Array.isArray(row.holes) ? row.holes : [];
  return {
    position: rowValue(row, ['rank', 'position', 'place', 'No', 'no']),
    name: rowValue(row, ['name', 'Name', 'player', 'Player']),
    rating: rowValue(row, ['rating', 'Rating']),
    toPar: rowValue(row, ['toPar', 'plusMinus']),
    holes: holes.map((hole) => ({
      hole: Number(hole.hole) || 0,
      score: valueAsString(hole.score),
      scoreClass: valueAsString(hole.scoreClass),
    })),
    rawScore: rowValue(row, ['rawScore', 'raw', 'Result', 'score']),
    handicap: rowValue(row, ['handicap', 'HC']),
    net: rowValue(row, ['handicapScore', 'net', 'Sum (Result-HC)']),
  };
}

function displayDivisions(round: { resultEvent?: PublicResultEvent | null }, event: EventDetail): DisplayDivision[] {
  const resultEvent = round.resultEvent ?? null;
  const publicKeys = publicDivisionKeys(resultEvent);
  if (resultEvent && publicKeys.length) {
    return publicKeys.map((key) => {
      const rows = (resultEvent.divisions?.[key] ?? []).map(publicDisplayRow);
      const maxHole = Math.max(18, ...rows.flatMap((row) => row.holes.map((hole) => hole.hole || 0)));
      return {
        label: key,
        rows,
        holeHeaders: Array.from({ length: maxHole }, (_, index) => index + 1),
      };
    });
  }

  return event.divisions.map((division) => ({
    label: division.letter,
    rows: division.players.map((player) => ({
      position: String(player.pos),
      name: player.name,
      rating: player.rating === null ? '' : String(player.rating),
      toPar: formatDiff(player.diff),
      holes: player.holes.map((score, holeIndex) => ({
        hole: holeIndex + 1,
        score: score === null ? '' : String(score),
        scoreClass: metrixHoleScoreClass(score, event.tracks[holeIndex]?.par ?? 3).replace('score-cell', '').replace('score-', '').trim(),
      })),
      rawScore: String(player.sum),
      handicap: fmt2(player.hc),
      net: fmt2(player.net),
    })),
    holeHeaders: event.tracks.map((_, index) => index + 1),
  }));
}

function displayHoleClass(hole: DisplayHole): string {
  const allowed = new Set(['holeinone', 'eagle', 'birdie', 'bogey', 'dbogey', 'fail']);
  return allowed.has(hole.scoreClass) ? `score-cell score-${hole.scoreClass}` : 'score-cell';
}

function totalDisplayPlayers(divisions: DisplayDivision[]): number {
  return divisions.reduce((sum, division) => sum + division.rows.length, 0);
}
---

<div class="social-results-browser" data-social-results-browser>
  <section class="results-topbar">
    <div>
      <p class="results-eyebrow">MDGC Social Days / Results</p>
      <h2>MDGC 2026 Social Day Results</h2>
      <p>{playedCount} of {rounds.length} rounds have imported scorecards.</p>
    </div>

    <div class="results-top-actions">
      <div class="season-switch" aria-label="Season selector">
        {seasons.map((item) => (
          item.id === season.id ? (
            <span class="season-switch-item is-active">{seasonShortLabel(item)}</span>
          ) : (
            <a class="season-switch-item" href={seasonHref(item)}>{seasonShortLabel(item)}</a>
          )
        ))}
      </div>
      <a class="result-top-button" href="/events/social">Info</a>
      <a class="result-top-button is-primary" href={`https://discgolfmetrix.com/${season.id}`} target="_blank" rel="noopener noreferrer">Metrix</a>
    </div>
  </section>

  <section class="results-browser-band">
    <div class="results-tabs" role="tablist" aria-label={`${seasonLabel} social days`}>
      {rounds.map((round, index) => {
        const id = tabId(round);
        const active = index === defaultIndex;
        return (
          <button
            id={`${id}-tab`}
            class={`results-tab ${active ? 'is-active' : ''}`}
            type="button"
            role="tab"
            aria-selected={active ? 'true' : 'false'}
            aria-controls={id}
            data-results-tab={id}
          >
            <strong>Rd {round.round} <em>{formatShortDate(round.date)}</em></strong>
            <span>{panelTitle(round)}</span>
          </button>
        );
      })}
    </div>

    <div class="results-panels">
      {rounds.map((round, index) => {
        const id = tabId(round);
        const active = index === defaultIndex;
        const event = round.detail;
        const resultEvent = round.resultEvent;
        const prizes = displayedPrizeRowsForResultEvent(resultEvent);
        const prizeNotes = prizeNotesForResultEvent(resultEvent);

        if (!event) {
          return (
            <section id={id} class="results-panel" role="tabpanel" aria-labelledby={`${id}-tab`} data-results-panel hidden={!active}>
              <div class="notice-card">
                <strong>Not played yet, check back later</strong>
                <a href={`https://discgolfmetrix.com/${round.id}`} target="_blank" rel="noopener noreferrer">Open on Metrix</a>
              </div>
            </section>
          );
        }

        return (
          <section id={id} class="results-panel" role="tabpanel" aria-labelledby={`${id}-tab`} data-results-panel hidden={!active}>
            <div class="results-panel-head">
              <div>
                <div class="results-panel-kicker">
                  <span>{seasonLabel}</span>
                  <span>Round {round.round}</span>
                </div>
                <h3>{panelTitle(round)}</h3>
                <p>{formatLongDate(panelDate(round))} | {panelEventTitle(round)}</p>
              </div>
              <div class="results-panel-actions">
                <span class="result-status imported">Imported</span>
                <a class="result-metrix-link" href={`https://discgolfmetrix.com/${round.id}`} target="_blank" rel="noopener noreferrer">Metrix</a>
                <a class="result-metrix-link" href={`${baseHref}/${season.id}/${round.id}`}>Full scorecard</a>
              </div>
            </div>

            <div class="results-section-grid">
              <section class="results-prize-section prize-graphic" aria-label="Prize winners">
                <div class="prize-graphic-head">
                  <div>
                    <span class="prize-graphic-kicker">MDGC Social Days</span>
                    <h3>Prize Winners</h3>
                    <p class="prize-graphic-event">
                      <strong>{panelTitle(round)}</strong>
                      <span>Round {round.round} | {formatLongDate(panelDate(round))}</span>
                    </p>
                  </div>
                  <img class="prize-card-logo" src="/images/social-results/mdgc-logo.png" alt="MDGC logo" />
                </div>

                <div class="prize-graphic-list">
                  {prizes.length ? prizes.map((row) => {
                    const kind = resultPrizeKind(row);
                    const detail = resultPrizeDetail(row);
                    return (
                      <article class={`prize-winner-row prize-row-${kind}`}>
                        <span class="prize-winner-icon" aria-hidden="true">
                          {kind === 'ctb' ? (
                            <svg viewBox="0 0 24 24">
                              <circle cx="12" cy="12" r="8"></circle>
                              <circle cx="12" cy="12" r="3"></circle>
                              <path d="M12 2v4M12 18v4M2 12h4M18 12h4"></path>
                            </svg>
                          ) : (
                            <svg viewBox="0 0 24 24">
                              <path d="M8 4h8v5a4 4 0 0 1-8 0V4Z"></path>
                              <path d="M8 6H5a3 3 0 0 0 3 5M16 6h3a3 3 0 0 1-3 5M12 13v4M9 20h6M10 17h4"></path>
                            </svg>
                          )}
                        </span>
                        <span class="prize-winner-copy">
                          <span class="prize-winner-type">{row.prize}</span>
                          <strong>{row.name}</strong>
                          {detail ? <em>{detail}</em> : null}
                        </span>
                      </article>
                    );
                  }) : (
                    <p class="results-empty prize-graphic-empty">No prize winners imported yet.</p>
                  )}
                </div>

                {prizeNotes.length ? (
                  <div class="prize-graphic-notes">
                    {prizeNotes.map((note) => <p>{note}</p>)}
                  </div>
                ) : null}
              </section>

              <section class="results-division-section">
                {(() => {
                  const divisions = displayDivisions(round, event);
                  return (
                    <>
                <div class="results-section-head">
                  <div>
                    <h3>Division Results</h3>
                    <p>{totalDisplayPlayers(divisions)} players across {divisions.length} divisions.</p>
                  </div>
                </div>

                <div class="result-division-grid">
                  {divisions.map((division) => (
                    <article class="result-division-block">
                      <div class="result-division-head">
                        <h4>Div {division.label}</h4>
                        <span>{division.rows.length} player{division.rows.length === 1 ? '' : 's'}</span>
                      </div>

                      <div class="results-table-wrap">
                        <table class="scorecard-table">
                          <thead>
                            <tr>
                              <th class="pos-col">Pos</th>
                              <th class="name-col">Name</th>
                              <th class="rating-col">Rating</th>
                              <th class="to-par-col">+/-</th>
                              {division.holeHeaders.map((holeNumber) => <th class="hole-col">{holeNumber}</th>)}
                              <th class="raw-col">Raw</th>
                              <th class="hc-col">HC</th>
                              <th class="net-col">Net</th>
                            </tr>
                          </thead>
                          <tbody>
                            {division.rows.map((player) => (
                              <tr>
                                <td class="pos-col">
                                  {[1, 2, 3].includes(Number(player.position)) ? <span class={`podium-badge podium-${player.position}`}>{player.position}</span> : player.position}
                                </td>
                                <td class="name-col">{player.name}</td>
                                <td class="rating-col">{player.rating || '-'}</td>
                                <td class="to-par-col">{player.toPar}</td>
                                {division.holeHeaders.map((holeNumber) => {
                                  const hole = player.holes.find((item) => item.hole === holeNumber) ?? { hole: holeNumber, score: '', scoreClass: '' };
                                  return <td class={displayHoleClass(hole)}>{hole.score || '-'}</td>;
                                })}
                                <td class="raw-col">{player.rawScore}</td>
                                <td class="hc-col">{player.handicap}</td>
                                <td class="net-col">{player.net}</td>
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </article>
                  ))}
                </div>
                    </>
                  );
                })()}
              </section>
            </div>
          </section>
        );
      })}
    </div>
  </section>
</div>

<script>
  document.querySelectorAll('[data-social-results-browser]').forEach((browser) => {
    const tabs = Array.from(browser.querySelectorAll('[data-results-tab]'));
    const panels = Array.from(browser.querySelectorAll('[data-results-panel]'));

    const activate = (panelId, updateHash = true, behavior = 'smooth') => {
      tabs.forEach((tab) => {
        const active = tab.dataset.resultsTab === panelId;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', String(active));
        if (active) tab.scrollIntoView({ behavior, block: 'nearest', inline: 'center' });
      });

      panels.forEach((panel) => {
        const active = panel.id === panelId;
        panel.toggleAttribute('hidden', !active);
      });

      if (updateHash) history.replaceState(null, '', `#${panelId}`);
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activate(tab.dataset.resultsTab, true, 'smooth'));
    });

    const initial = location.hash.replace('#', '');
    const initialTab = tabs.find((tab) => tab.dataset.resultsTab === initial) || tabs.find((tab) => tab.classList.contains('is-active')) || tabs[0];
    if (initialTab) activate(initialTab.dataset.resultsTab, false, 'auto');
  });
</script>

<style>
  .social-results-browser {
    margin-inline: auto;
    max-width: 1320px;
  }

  .results-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 16px;
    border-radius: 8px;
    background:
      linear-gradient(115deg, rgba(5, 7, 8, 0.98) 0%, rgba(6, 61, 99, 0.97) 58%, rgba(34, 122, 183, 0.94) 100%),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 18px);
    color: white;
    padding: 14px 18px;
  }

  .results-eyebrow {
    margin: 0 0 4px;
    color: var(--color-mdgc-amber);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .results-topbar h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 900;
    line-height: 1.1;
  }

  .results-topbar p {
    margin: 5px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 13px;
  }

  .results-top-actions,
  .season-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .season-switch {
    padding: 4px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.12);
  }

  .season-switch-item,
  .result-top-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    border-radius: 6px;
    padding: 5px 10px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 12px;
    font-weight: 850;
    text-decoration: none;
  }

  .season-switch-item.is-active {
    background: #ffffff;
    color: var(--color-mdgc-accent-deep);
  }

  .result-top-button {
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  .result-top-button.is-primary {
    background: var(--color-mdgc-accent);
    border-color: var(--color-mdgc-accent);
  }

  .results-tabs {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scrollbar-width: thin;
    border: 1px solid var(--color-mdgc-blue-light);
    border-radius: 8px;
    background: linear-gradient(180deg, #ffffff, #eaf6fd);
    box-shadow: 0 10px 28px rgba(6, 61, 99, 0.1);
    padding: 8px;
  }

  .results-tab {
    flex: 0 0 92px;
    min-height: 54px;
    min-width: 0;
    border: 1px solid rgba(183, 215, 233, 0.9);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: inset 0 -2px 0 rgba(57, 160, 223, 0.08);
    color: var(--color-mdgc-ink);
    cursor: pointer;
    font: inherit;
    padding: 7px 8px;
    text-align: left;
  }

  .results-tab:hover {
    border-color: var(--color-mdgc-accent);
    background: white;
  }

  .results-tab.is-active {
    border-color: var(--color-mdgc-blue);
    background: linear-gradient(180deg, var(--color-mdgc-accent), var(--color-mdgc-blue));
    box-shadow: 0 9px 18px rgba(6, 61, 99, 0.2), inset 0 -3px 0 var(--color-mdgc-amber);
    color: white;
  }

  .results-tab strong {
    display: flex;
    align-items: baseline;
    gap: 5px;
    font-size: 13px;
    line-height: 1.1;
  }

  .results-tab em {
    color: var(--color-text-body);
    font-size: 11px;
    font-style: normal;
    font-weight: 650;
  }

  .results-tab.is-active em {
    color: rgba(255, 255, 255, 0.82);
  }

  .results-tab span {
    display: block;
    margin-top: 4px;
    overflow: hidden;
    color: var(--color-text-body);
    font-size: 11px;
    font-weight: 700;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .results-tab.is-active span {
    color: rgba(255, 255, 255, 0.78);
  }

  .results-panels {
    margin-top: 18px;
  }

  .results-panel[hidden] {
    display: none;
