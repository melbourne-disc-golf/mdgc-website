---
import { Temporal } from '@js-temporal/polyfill';
import type { CalendarEvent } from '@utils/events';
import { externalLinkAttrs } from '@utils/links';

interface Props {
  events: CalendarEvent[];
  maxDaysInPast?: number;
  maxDaysInFuture?: number;
}

const { events, maxDaysInPast, maxDaysInFuture } = Astro.props;
const sortedEvents = [...events].sort((a, b) => Temporal.PlainDate.compare(a.startDate, b.startDate));

const WEEKDAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

function getDayOfWeek(date: Temporal.PlainDate): string {
  return WEEKDAYS[date.dayOfWeek - 1];
}

function getDayNames(start: Temporal.PlainDate, end?: Temporal.PlainDate): string[] {
  const names = [getDayOfWeek(start)];
  let current = start.add({ days: 1 });
  while (end && Temporal.PlainDate.compare(current, end) <= 0) {
    names.push(getDayOfWeek(current));
    current = current.add({ days: 1 });
  }
  return names;
}

function getMonthKey(date: Temporal.PlainDate): string {
  return `${date.year}-${date.month}`;
}

function getMonthLabel(date: Temporal.PlainDate): string {
  return `${MONTHS[date.month - 1]} ${date.year}`;
}

// Group events by month
type MonthGroup = {
  key: string;
  label: string;
  events: CalendarEvent[];
};

const groupedByMonth: MonthGroup[] = [];
let currentGroup: MonthGroup | null = null;

for (const event of sortedEvents) {
  const monthKey = getMonthKey(event.startDate);
  const monthLabel = getMonthLabel(event.startDate);

  if (!currentGroup || currentGroup.key !== monthKey) {
    currentGroup = { key: monthKey, label: monthLabel, events: [] };
    groupedByMonth.push(currentGroup);
  }
  currentGroup.events.push(event);
}

function getEventSourceClass(event: CalendarEvent): string {
  return `event-${event.source || 'other'}`;
}
---

{sortedEvents.length === 0 ? (
  <p class="no-events">No events scheduled at the moment. Check back soon!</p>
) : (
  <div
    class="event-calendar"
    data-max-days-in-past={maxDaysInPast}
    data-max-days-in-future={maxDaysInFuture}
  >
    {groupedByMonth.map((group) => (
      <div class="month-group">
        <div class="month-inner">
          <h3 class="month-header">{group.label}</h3>
          <div class="events-list">
            {group.events.map((event) => {
              const rowContent = (
                <>
                  <div class="event-date">
                    <span class="day-number">{event.startDate.day}</span>
                    {getDayNames(event.startDate, event.endDate).map((name) => (
                      <span class="day-name">{name}</span>
                    ))}
                  </div>
                  <div class="event-details">
                    <div class="event-title">
                      {event.summary}
                      {event.external && <span class="external-icon"> ↗</span>}
                    </div>
                    {event.location && (
                      <div class="event-location">{event.location}</div>
                    )}
                  </div>
                </>
              );
              const row = event.url ? (
                <a href={event.url} class={`event-row clickable ${getEventSourceClass(event)}`} data-date={event.startDate.toString()} {...externalLinkAttrs(event.url ?? '')}>
                  {rowContent}
                </a>
              ) : (
                <div class={`event-row ${getEventSourceClass(event)}`} data-date={event.startDate.toString()}>
                  {rowContent}
                </div>
              );
              return (
                <div class="event-collapse">
                  <div class="event-clip">{row}</div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    ))}
  </div>
)}

<style>
  .event-calendar {
    margin: 1rem 0;
  }

  /* month-group and event-collapse use the grid-template-rows 1fr→0fr trick to
     animate height when the "Include non-MDGC events" toggle collapses them.
     The .collapsed class is added by the script in EventCalendar.astro. */
  .month-group {
    display: grid;
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.28s ease, opacity 0.28s ease;
  }

  .month-group.collapsed {
    grid-template-rows: 0fr;
    opacity: 0;
  }

  .month-inner {
    min-height: 0;
    overflow: hidden;
    /* Horizontal breathing room so a hovered tile's zoom and drop-shadow aren't
       clipped sideways. The clip still bounds vertical overflow for the collapse. */
    padding-inline: 1.5rem;
    margin-inline: -1.5rem;
  }

  .month-header {
    font-weight: 600;
    border-bottom: 1px solid var(--color-border, #e5e5e5);
  }

  /* Spacing lives on inner content (not padding on .month-inner) so it's clipped
     away when the group collapses — padding on the clip would leave a residual. */
  .events-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.5rem;
  }

  .event-collapse {
    display: grid;
    grid-template-rows: 1fr;
    position: relative;
    margin-bottom: 0.5rem; /* row spacing; collapses with the row (events-list has no gap) */
    border-radius: 0.5rem;
    box-shadow: var(--panel-shadow);
    transition: grid-template-rows 0.28s ease, opacity 0.28s ease, transform 0.2s ease,
      box-shadow 0.2s ease, margin-bottom 0.28s ease;
  }

  .event-collapse.collapsed {
    grid-template-rows: 0fr;
    opacity: 0;
    margin-bottom: 0;
    box-shadow: none;
  }

  .event-clip {
    min-height: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  /* Hover treatment shared with link panels: subtle zoom, deeper drop-shadow,
     and border/text darkening — no background change. Scaling the wrapper (not
     the clipped row) keeps the tile from being cut off. */
  .event-collapse:hover {
    transform: scale(var(--hover-zoom-scale));
    box-shadow: var(--panel-shadow-hover);
    z-index: 1;
  }

  /* The thin (top/right/bottom) borders are a faint tint of the accent at rest,
     and ramp to full opacity on hover. The thick left bar stays fully opaque. */
  .event-collapse:hover .event-row {
    border-color: var(--accent);
  }

  .event-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--accent, #d1d5db), transparent 70%);
    border-left-width: 4px;
    border-left-color: var(--accent, #d1d5db); /* left accent bar stays fully opaque */
    --title-color: #1f2937;
    transition: all 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .month-group,
    .event-collapse {
      transition: none;
    }
    .event-collapse:hover {
      transform: none;
    }
  }

  a.event-row {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transform: none; /* the wrapper (.event-collapse) does the hover zoom */
  }

  .event-club {
    background: #dcfce7;
    --accent: #16a34a;
  }

  .event-social {
    background: #fefce8;
    --accent: #eab308;
  }

  /* Non-MDGC events are less prominent: white tile, lightened event name. */
  .event-external {
    background: #ffffff;
    --accent: #9ca3af;
    --title-color: #6b7280;
  }

  .event-other {
    background: #f9fafb;
    --accent: #d1d5db;
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 3rem;
    text-align: center;
  }

  .day-number {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--color-text, #111827);
    transition: color 0.2s ease;
  }

  .day-name {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--color-text-muted, #6b7280);
    letter-spacing: 0.025em;
  }

  .past-event {
    opacity: 0.4;
  }

  .event-details {
    flex: 1;
    min-width: 0;
  }

  .event-title {
    font-weight: 500;
    font-size: 1rem;
    flex: 1;
    color: var(--title-color);
    transition: all 0.2s ease;
  }

  .external-icon {
    font-size: 0.85em;
    opacity: 0.6;
  }

  .event-location {
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
  }

  @media (min-width: 640px) {
    .event-details {
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    .event-location {
      margin-top: 0;
      flex-shrink: 0;
    }
  }

  .no-events {
    color: var(--color-text-muted, #6b7280);
    font-style: italic;
  }

  .hidden {
    display: none;
  }

  @media (max-width: 480px) {
    .event-row {
      padding: 0.5rem;
    }

    .day-number {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  // Filter events based on configurable date range and mark past events
  document.querySelectorAll('.event-calendar').forEach((calendar) => {
    const maxDaysInPast = calendar.getAttribute('data-max-days-in-past');
    const maxDaysInFuture = calendar.getAttribute('data-max-days-in-future');

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const minDate = maxDaysInPast
      ? new Date(today.getTime() - parseInt(maxDaysInPast) * 24 * 60 * 60 * 1000)
      : null;
    const maxDate = maxDaysInFuture
      ? new Date(today.getTime() + parseInt(maxDaysInFuture) * 24 * 60 * 60 * 1000)
      : null;

    calendar.querySelectorAll('.event-row[data-date]').forEach((row) => {
      const eventDate = new Date(row.getAttribute('data-date')!);

      // Dim past events
      if (eventDate < today) {
        row.classList.add('past-event');
      }

      // Hide events outside date range
      if ((minDate && eventDate < minDate) || (maxDate && eventDate > maxDate)) {
        row.classList.add('hidden');
      }
    });

    // Hide month groups with no visible events
    calendar.querySelectorAll('.month-group').forEach((group) => {
      const visibleEvents = group.querySelectorAll('.event-row:not(.hidden)');
      if (visibleEvents.length === 0) {
        group.classList.add('hidden');
      }
    });
  });
</script>
