---
import '@styles/global.css'
import { Font } from 'astro:assets';
import defaultOgImage from '@images/ruffey-lake-hole-1.jpg';
import { getNavItems, type NavItem } from '@data/navigation.ts';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PageHero, { type HeroImage, type BackLink } from '@components/PageHero.astro';

export type { HeroImage, BackLink };

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;  // for og:description, falls back to subtitle
  heroImage?: HeroImage;
  canonicalPath?: string;  // override when a default route mirrors a canonical child page
  cmsPath?: string;  // e.g., '/collections/courses/entries/bald-hill-park'
  backLink?: BackLink;  // override the automatic (nav-derived) back-link
}

const { title, subtitle, description, heroImage, canonicalPath, cmsPath, backLink: backLinkProp } = Astro.props;

// Build page metadata
const pageTitle = `${title} | Melbourne Disc Golf Club`;
const pageDescription = description || subtitle || 'Melbourne Disc Golf Club - promoting disc golf in Melbourne since 2007';
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, Astro.site);
const ogImageUrl = heroImage
  ? new URL(heroImage.src.src, Astro.site)
  : new URL(defaultOgImage.src, Astro.site);

const currentPath = Astro.url.pathname;

// Get navigation items dynamically
const navItems: NavItem[] = await getNavItems();

// Systematic back-link: the nearest ancestor of the current path that appears
// in the navigation (e.g. /club/membership → /club "Club"). Saves having to add
// tactical per-page back-links. Top-level pages get none — the logo above
// already links Home.
const titleByPath = new Map<string, string>();
for (const item of navItems) {
  titleByPath.set(item.href, item.title);
  for (const sub of item.subPages ?? []) titleByPath.set(sub.href, sub.title);
}
function computeBackLink(path: string): BackLink | null {
  const parts = path.replace(/\/+$/, '').split('/').filter(Boolean);
  for (let i = parts.length - 1; i >= 1; i--) {
    const ancestor = '/' + parts.slice(0, i).join('/');
    const text = titleByPath.get(ancestor);
    if (text) return { href: ancestor, text };
  }
  return null;
}
// An explicit backLink prop overrides the automatic one.
const backLink = backLinkProp ?? computeBackLink(currentPath);


// Favicon sizes to generate links for
const faviconSizes = [16, 32, 48, 192];
---

<!doctype html>
<html lang="en">
	<head>
		<title>{pageTitle}</title>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={pageDescription} />

		<Font cssVariable="--font-hanken" preload />
		<Font cssVariable="--font-outfit" preload />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:site_name" content="Melbourne Disc Golf Club" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="canonical" href={canonicalUrl} />
		{faviconSizes.map(size => (
			<link rel="icon" type="image/png" sizes={`${size}x${size}`} href={`/images/favicon-${size}x${size}.png`} />
		))}
	</head>
	<body class="flex flex-col min-h-screen bg-mdgc-mist">
		<Header navItems={navItems} currentPath={currentPath} />

		<main class="grow">
			<PageHero title={title} subtitle={subtitle} heroImage={heroImage} backLink={backLink} />
			<div class="content-width">
				<slot />
			</div>
		</main>

		<Footer navItems={navItems} currentPath={currentPath} cmsPath={cmsPath} />

	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>

<script src="../scripts/heading-links.ts"></script>
