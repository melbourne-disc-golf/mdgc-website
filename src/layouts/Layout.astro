---
import '@styles/global.css';
import logoImage from '@images/mdgc-logo.png';
import defaultOgImage from '@images/ruffey-lake-hole-1.jpg';
import { getNavItems, type NavItem } from '@data/navigation.ts';
import { Icon } from 'astro-icon/components';
import ReportIssue from '@components/ReportIssue.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface HeroImage {
  src: ImageMetadata;
  alt: string;
  class?: string;
  caption?: string;
}

export interface BackLink {
  href: string;
  text: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  heroImage?: HeroImage;
  cmsPath?: string;
  backLink?: BackLink;
}

const { title, subtitle, description, heroImage, cmsPath, backLink: backLinkProp } = Astro.props;

const pageTitle = `${title} | Melbourne Disc Golf Club`;
const pageDescription = description || subtitle || 'Melbourne Disc Golf Club - promoting disc golf in Melbourne since 2007';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = heroImage
  ? new URL(heroImage.src.src, Astro.site)
  : new URL(defaultOgImage.src, Astro.site);

const currentPath = Astro.url.pathname;
const navItems: NavItem[] = await getNavItems();

function isActiveNavItem(itemHref: string): boolean {
  if (itemHref === '/' && currentPath === '/') return true;
  if (itemHref !== '/' && currentPath.startsWith(itemHref)) return true;
  return false;
}

const titleByPath = new Map<string, string>();
for (const item of navItems) {
  titleByPath.set(item.href, item.title);
  for (const sub of item.subPages ?? []) titleByPath.set(sub.href, sub.title);
}

function computeBackLink(path: string): BackLink | null {
  const parts = path.replace(/\/+$/, '').split('/').filter(Boolean);
  for (let i = parts.length - 1; i >= 1; i--) {
    const ancestor = '/' + parts.slice(0, i).join('/');
    const text = titleByPath.get(ancestor);
    if (text) return { href: ancestor, text };
  }
  return null;
}

const backLink = backLinkProp ?? computeBackLink(currentPath);
const githubUrl = 'https://github.com/melbourne-disc-golf/mdgc-website';
const cmsUrl = cmsPath ? `/cms/sveltia#${cmsPath}` : null;
const faviconSizes = [16, 32, 48, 192];

function navItemClass(itemHref: string): string {
  return isActiveNavItem(itemHref)
    ? 'bg-white text-slate-950 shadow-sm'
    : 'text-slate-200 hover:bg-white/10 hover:text-white';
}

function submenuItemClass(itemHref: string): string {
  return isActiveNavItem(itemHref)
    ? 'bg-mdgc-green text-white'
    : 'text-slate-700 hover:bg-slate-100 hover:text-slate-950';
}

function footerLinkClass(itemHref: string): string {
  return isActiveNavItem(itemHref) ? 'text-white' : 'text-slate-400';
}
---

<!doctype html>
<html lang="en">
  <head>
    <title>{pageTitle}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Melbourne Disc Golf Club" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="canonical" href={canonicalUrl} />
    {faviconSizes.map(size => (
      <link rel="icon" type="image/png" sizes={`${size}x${size}`} href={`/images/favicon-${size}x${size}.png`} />
    ))}
  </head>
  <body class="flex min-h-screen flex-col bg-mdgc-paper text-slate-900 antialiased">
    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/95 text-white shadow-sm backdrop-blur">
      <div id="menu-content" class="content-width flex min-h-[4.5rem] items-center gap-5 py-3">
        <a href="/" title="Home" class="logo-link flex items-center gap-3">
          <img src={logoImage.src} alt="Melbourne Disc Golf Club" class="h-12 w-auto" />
          <span class="hidden font-display text-base font-extrabold leading-tight tracking-normal sm:block">
            Melbourne<br class="lg:hidden" /> Disc Golf
          </span>
        </a>

        <nav class="ml-auto hidden items-center gap-1 md:flex" aria-label="Main navigation">
          {navItems.map(item => (
            item.subPages ? (
              <div class="group relative">
                <a href={item.href} class={`inline-flex items-center gap-1 rounded-md px-3 py-2 text-sm font-semibold transition-colors ${navItemClass(item.href)}`}>
                  {item.icon && <Icon name={item.icon} class="h-4 w-4" />}
                  {item.title}
                </a>
                <div class="invisible absolute right-0 top-full min-w-56 pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100">
                  <div class="rounded-md border border-slate-200 bg-white p-2 text-slate-900 shadow-xl">
                    {item.subPages.map(subItem => (
                      <a href={subItem.href} class={`flex items-center gap-2 rounded-md px-3 py-2 text-sm transition-colors ${submenuItemClass(subItem.href)}`}>
                        {subItem.icon && <Icon name={subItem.icon} class="h-4 w-4" />}
                        <span>{subItem.title}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={item.href} class={`inline-flex items-center gap-1 rounded-md px-3 py-2 text-sm font-semibold transition-colors ${navItemClass(item.href)}`}>
                {item.icon && <Icon name={item.icon} class="h-4 w-4" />}
                {item.title}
              </a>
            )
          ))}
        </nav>

        <button id="mobile-menu-button" class="ml-auto rounded-md border border-white/15 p-2 text-slate-100 hover:bg-white/10 md:hidden" aria-label="Toggle mobile menu" aria-expanded="false">
          <Icon name="heroicons:bars-3" class="h-6 w-6" />
        </button>
      </div>

      <div id="mobile-menu" class="hidden border-t border-white/10 bg-slate-950 md:hidden">
        <nav class="content-width space-y-2 py-3" aria-label="Mobile navigation">
          {navItems.map(item => (
            item.subPages ? (
              <div class="rounded-md bg-white/5 p-2">
                <a href={item.href} class={`flex items-center gap-2 rounded-md px-3 py-2 text-sm font-bold ${isActiveNavItem(item.href) ? 'bg-white text-slate-950' : 'text-slate-100'}`}>
                  {item.icon && <Icon name={item.icon} class="h-4 w-4" />}
                  {item.title}
                </a>
                <div class="mt-1 grid gap-1 pl-4">
                  {item.subPages.map(subItem => (
                    <a href={subItem.href} class={`rounded-md px-3 py-2 text-sm ${isActiveNavItem(subItem.href) ? 'bg-mdgc-green text-white' : 'text-slate-300 hover:bg-white/10 hover:text-white'}`}>
                      {subItem.title}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={item.href} class={`flex items-center gap-2 rounded-md px-3 py-2 text-sm font-bold ${isActiveNavItem(item.href) ? 'bg-white text-slate-950' : 'text-slate-100 hover:bg-white/10'}`}>
                {item.icon && <Icon name={item.icon} class="h-4 w-4" />}
                {item.title}
              </a>
            )
          ))}
        </nav>
      </div>
    </header>

    <main class="grow">
      {heroImage ? (
        <section class="relative isolate overflow-hidden bg-slate-950 text-white">
          <Image
            src={heroImage.src}
            alt={heroImage.alt}
            fit="cover"
            class="absolute inset-0 -z-20 h-full w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 -z-10 bg-slate-950/55"></div>
          <div class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-linear-to-t from-mdgc-paper to-transparent"></div>
          <div class="content-width flex min-h-[26rem] items-end pb-14 pt-20 sm:min-h-[30rem]">
            <div class="max-w-3xl">
              {backLink && (
                <a href={backLink.href} class="no-print mb-5 inline-flex items-center rounded-md bg-white/10 px-3 py-1.5 text-sm font-semibold text-white backdrop-blur hover:bg-white/20">
                  &larr; {backLink.text}
                </a>
              )}
              <p class="mb-3 text-sm font-bold uppercase tracking-[0.16em] text-mdgc-mint">Melbourne Disc Golf Club</p>
              <h1 class="font-display text-5xl font-black leading-none sm:text-6xl lg:text-7xl">{title}</h1>
              {subtitle && <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-100 sm:text-xl">{subtitle}</p>}
            </div>
          </div>
          {heroImage.caption && (
            <p class="content-width -mt-9 pb-5 text-xs text-slate-200/80">{heroImage.caption}</p>
          )}
        </section>
      ) : (
        <section class="bg-slate-950 text-white">
          <div class={`content-width ${backLink ? 'pb-9 pt-5' : 'py-10'}`}>
            {backLink && (
              <a href={backLink.href} class="no-print mb-5 inline-flex items-center rounded-md bg-white/10 px-3 py-1.5 text-sm font-semibold text-slate-100 hover:bg-white/20">
                &larr; {backLink.text}
              </a>
            )}
            <p class="mb-2 text-sm font-bold uppercase tracking-[0.16em] text-mdgc-mint">Melbourne Disc Golf Club</p>
            <h1 class="font-display text-4xl font-black leading-tight sm:text-5xl">{title}</h1>
            {subtitle && <p class="mt-3 max-w-3xl text-lg leading-8 text-slate-200">{subtitle}</p>}
          </div>
        </section>
      )}

      <div class="content-width py-10 sm:py-12">
        <slot />
      </div>
    </main>

    <footer class="mt-auto bg-slate-950 py-12 text-white sm:px-6 lg:px-8">
      <div class="no-print content-width grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,2fr)]">
        <div>
          <a href="/" title="Home" class="logo-link inline-flex items-center gap-3">
            <img src={logoImage.src} alt="Melbourne Disc Golf Club" class="h-14 w-auto" />
            <span class="font-display text-xl font-black">Melbourne Disc Golf</span>
          </a>
          <p class="mt-4 max-w-md text-sm leading-6 text-slate-400">
            Local courses, social rounds, club events and community disc golf across Melbourne.
          </p>
        </div>

        <nav class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5" aria-label="Footer navigation">
          {navItems.map((section) => (
            <div>
              <h3 class="mb-3 font-semibold">
                <a href={section.href} class={`inline-flex items-center gap-1 whitespace-nowrap ${footerLinkClass(section.href)} hover:text-white`}>
                  {section.icon && <Icon name={section.icon} class="h-4 w-4" />}
                  {section.title}
                </a>
              </h3>
              {section.subPages && (
                <ul class="space-y-2">
                  {section.subPages.map(link => (
                    <li>
                      <a href={link.href} class={`text-sm ${footerLinkClass(link.href)} hover:text-white`}>
                        {link.title}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </nav>
      </div>

      <div class="content-width mt-10 flex flex-col gap-4 border-t border-white/10 pt-5 md:flex-row md:items-center md:justify-between">
        <div class="text-sm text-slate-500">
          <p>&copy; {new Date().getFullYear()} Melbourne Disc Golf Club. All rights reserved.</p>
          <p class="mt-1 text-xs">Last updated: {new Date().toLocaleString('en-AU', { timeZone: 'Australia/Melbourne', dateStyle: 'medium', timeStyle: 'short' })}</p>
        </div>
        <div class="no-print flex items-center gap-4">
          {cmsUrl && (
            <a href={cmsUrl} target="_blank" rel="noopener noreferrer" class="inline-flex rounded-md p-2 text-slate-400 hover:bg-white/10 hover:text-white" aria-label="Edit page in CMS" title="Edit in CMS">
              <Icon name="mdi:pencil" class="h-5 w-5" />
            </a>
          )}
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex rounded-md p-2 text-slate-400 hover:bg-white/10 hover:text-white" aria-label="View source on GitHub" title="View source on GitHub">
            <Icon name="mdi:github" class="h-5 w-5" />
          </a>
          <ReportIssue />
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  @import "tailwindcss";

  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }

  .logo-link {
    text-decoration: none;
  }

  footer nav a {
    @apply transition-colors;
  }

  @media print {
    .no-print {
      display: none;
    }
  }
</style>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    const expanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    mobileMenuButton.setAttribute('aria-expanded', String(!expanded));
  });
</script>

<script src="../scripts/heading-links.ts"></script>
